                    <button class="btn btn-primary" id="savePrnBtn"
                        style="padding:1.2rem 3rem; font-size:1.1rem; border-radius:1rem; font-weight:600; background: var(--gradient-pink-orange); border: none;">
                        <i class="fas fa-save"></i> Enregistrer
                    </button>
                </div>
            </div>
