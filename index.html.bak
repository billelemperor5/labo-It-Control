                                <i class="fas fa-info-circle" style="margin-right: 0.25rem;"></i> Statut
                            </label>
                            <div class="premium-input-wrapper">
                                <select id="addPrnStatus">
                                    <option>En Ligne (Actif)</option>
                                    <option>Hors Ligne (Panne)</option>
                                    <option>En Maintenance</option>
                                </select>
                            </div>
                        </div>
                    </div>
