                    <button class="btn"
                        style="padding:1.2rem 3rem; font-size:1.1rem; border-radius:1rem; font-weight:600; background:var(--bg-secondary); color:var(--text-primary); border:2px solid var(--border-color);"
                        onclick="closeStockForm()">
                        <i class="fas fa-times"></i> Annuler
                    </button>
                    <button class="btn btn-primary" id="saveStockBtn"
                        style="padding:1.2rem 3rem; font-size:1.1rem; border-radius:1rem; font-weight:600; background: var(--gradient-cyan-blue); border: none;"
                        onclick="saveStockItem()">
