<!DOCTYPE html>
<html lang="fr" dir="ltr">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>LABO-IT CONTROL | Système de Gestion de Laboratoire Informatique</title>

    <!-- PWA Support -->
    <link rel="manifest" href="manifest.json">
    <meta name="theme-color" content="#0f172a">
    <meta name="mobile-web-app-capable" content="yes">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
    <link rel="icon" type="image/png" href="assets/icon_192.png">
    <link rel="apple-touch-icon" href="assets/icon_192.png">

    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link
        href="https://fonts.googleapis.com/css2?family=Montserrat:wght@500;600;700&amp;family=Playfair+Display:ital,wght@0,500;0,700;1,500&amp;display=swap"
        rel="stylesheet">
    <script>
        window.LABO_IT_ASSET_VERSION = '2.2.0';
        (function refreshOldPwaCache() {
            const supportsPwaOrigin = window.location.protocol === 'http:' || window.location.protocol === 'https:';
            const versionKey = 'laboItAssetVersion';
            const currentVersion = window.LABO_IT_ASSET_VERSION;
            try {
                if (localStorage.getItem(versionKey) === currentVersion) return;
            } catch (error) {
                return;
            }

            Promise.all([
                supportsPwaOrigin && 'caches' in window
                    ? caches.keys().then((keys) => Promise.all(
                        keys.filter((key) => key.startsWith('labo-it-cache-')).map((key) => caches.delete(key))
                    ))
                    : Promise.resolve(),
                supportsPwaOrigin && 'serviceWorker' in navigator
                    ? navigator.serviceWorker.getRegistrations().then((registrations) => Promise.all(
                        registrations.map((registration) => registration.update())
                    ))
                    : Promise.resolve()
            ]).finally(() => {
                try {
                    localStorage.setItem(versionKey, currentVersion);
                } catch (error) {
                    // Storage can be unavailable on some local/private browser contexts.
                }
            });
        })();
    </script>
    <link rel="stylesheet" href="css/style.css?v=2.2.0">

</head>

<body data-theme="light">

    <!-- ============ شاشة اترحب ============ -->
    <div class="welcome-screen" id="welcomeScreen">
        <div class="welcome-bg-elements">
            <div class="orb orb-1" style="opacity: 0.2; width: 600px; height: 600px;"></div>
            <div class="orb orb-2" style="opacity: 0.2; width: 500px; height: 500px;"></div>
            <div class="tech-grid" style="opacity: 0.08;"></div>
            <div class="welcome-circuit-lines"></div>
            <div class="welcome-glass-panel welcome-glass-panel-left"></div>
            <div class="welcome-glass-panel welcome-glass-panel-right"></div>
        </div>

        <div class="welcome-content">
            <!-- Microchip Logo as in previous design -->
            <div class="welcome-logo-outer">
                <div class="logo-ring"></div>
                <div class="welcome-logo">
                    <i class="fas fa-microchip"></i>
                </div>
            </div>

            <!-- Generalized Grand Brand Title -->
            <div class="welcome-brand-container">
                <div class="welcome-brand-top-line"></div>
                <div class="welcome-brand-main-text">
                    <span class="welcome-brand-char-l">L</span>
                    <span class="welcome-brand-star-wrapper">
                        <svg viewBox="85 15 75 80" class="welcome-brand-star-svg">
                            <path
                                d="M 148,22 C 141,43 135,48 130,54 C 135,60 142,65 147,73 C 135,68 129,64 123,62 C 115,72 109,80 102,88 C 109,72 112,64 115,54 C 105,50 95,48 89,45 C 105,43 112,43 119,45 C 129,36 139,28 148,22 Z" />
                        </svg>
                    </span>
                    <span class="welcome-brand-text-right">BONEDJMA</span>
                </div>
                <div class="welcome-brand-subtitle">LABORATOIRES COSMÉTIQUES</div>
                <div class="welcome-brand-bottom-line"></div>
            </div>

            <div class="welcome-system-name">LABO-IT CONTROL</div>
            <p class="welcome-subtitle">PORTAIL TECHNIQUE &amp; SYSTEME DE CONTRIT</p>
            <button class="welcome-btn" onclick="enterSystem()">
                Entrer dans le Système <i class="fas fa-sign-in-alt" style="margin-left: 10px;"></i>
            </button>
        </div>

        <div class="welcome-author">By.Billel-Bouraba</div>
        <div class="welcome-footer">
            <span><i class="fas fa-shield-alt"></i> Système Sécurisé</span>
            <span><i class="fas fa-cloud"></i> Données Cloud</span>
            <span><i class="fas fa-bolt"></i> Performance Rapide</span>
            <span><i class="fas fa-code"></i> Version 2.2.0</span>
        </div>
    </div>

    <!-- Beautiful Custom Intervention Pop-up Modal -->
    <div id="customInterventionOverlay" class="modal-overlay" onclick="closeCustomInterventionModalOuter(event)">
        <div class="modal"
            style="max-width: 480px; border-radius: 1.5rem; background: var(--bg-secondary); border: 1px solid var(--border-color); box-shadow: var(--shadow-2xl); padding: 2rem;">
            <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1.5rem;">
                <h3 id="customInterventionTitle"
                    style="margin: 0; font-size: 1.4rem; font-weight: 700; background: var(--gradient-blue-purple); -webkit-background-clip: text; -webkit-text-fill-color: transparent; display: flex; align-items: center; gap: 0.5rem; background-clip: text;">
                    <i class="fas fa-tools" style="color: var(--indigo-500);"></i> Déclarer une Intervention
                </h3>
                <button onclick="closeCustomInterventionModal()"
                    style="background: none; border: none; color: var(--text-muted); font-size: 1.2rem; cursor: pointer;">
                    <i class="fas fa-times"></i>
                </button>
            </div>

            <div class="form-group" style="margin-bottom: 1.2rem;">
                <label
                    style="display: block; font-size: 0.85rem; font-weight: 600; color: var(--text-primary); margin-bottom: 0.5rem;">Type
                    d'Intervention</label>
                <select id="custIntType"
                    style="width: 100%; padding: 0.85rem 1rem; border-radius: 0.75rem; border: 1px solid var(--border-color); background: var(--bg-card); color: var(--text-primary); outline: none; font-size: 0.95rem;"
                    onchange="toggleCustomInterventionType()">
                    <option value="Maintenance">Maintenance Générale</option>
                    <option value="Réparation">Réparation Matérielle</option>
                    <option value="Remplacement">Remplacement de Composant</option>
                    <option value="Installation">Installation Logicielle / Config</option>
                    <option value="Nettoyage">Nettoyage & Entretien</option>
                    <option value="Diagnostic">Diagnostic & Audit</option>
                    <option value="Autre">Autre...</option>
                </select>
            </div>

            <div class="form-group" id="custIntCustomTypeContainer" style="margin-bottom: 1.2rem; display: none;">
                <label
                    style="display: block; font-size: 0.85rem; font-weight: 600; color: var(--text-primary); margin-bottom: 0.5rem;">Spécifiez
                    le Type d'Intervention</label>
                <input type="text" id="custIntCustomType" placeholder="Ex: Mise à niveau matérielle, Audit sécurité..."
                    style="width: 100%; padding: 0.85rem 1rem; border-radius: 0.75rem; border: 1px solid var(--border-color); background: var(--bg-card); color: var(--text-primary); outline: none; font-size: 0.95rem;">
            </div>

            <div class="form-group" style="margin-bottom: 1.2rem;">
                <label
                    style="display: block; font-size: 0.85rem; font-weight: 600; color: var(--text-primary); margin-bottom: 0.5rem;">Description
                    des Travaux</label>
                <textarea id="custIntDesc" rows="3" placeholder="Description détaillée..."
                    style="width: 100%; padding: 0.85rem 1rem; border-radius: 0.75rem; border: 1px solid var(--border-color); background: var(--bg-card); color: var(--text-primary); outline: none; font-size: 0.95rem; resize: none;"></textarea>
            </div>

            <div class="form-group" style="margin-bottom: 2rem;">
                <label
                    style="display: block; font-size: 0.85rem; font-weight: 600; color: var(--text-primary); margin-bottom: 0.5rem;">Technicien
                    Intervenant</label>
                <input type="text" id="custIntTech" value="Ali S."
                    style="width: 100%; padding: 0.85rem 1rem; border-radius: 0.75rem; border: 1px solid var(--border-color); background: var(--bg-card); color: var(--text-primary); outline: none; font-size: 0.95rem;">
            </div>

            <div style="display: flex; gap: 1rem; justify-content: flex-end;">
                <button class="btn" onclick="closeCustomInterventionModal()"
                    style="background: var(--bg-secondary); border: 2px solid var(--border-color); color: var(--text-primary); font-weight: 600; padding: 0.75rem 1.5rem; border-radius: 0.75rem; cursor: pointer;">
                    Annuler
                </button>
                <button class="btn btn-primary" id="custIntSaveBtn" onclick="saveCustomIntervention()"
                    style="background: var(--gradient-blue-purple); border: none; color: white; font-weight: 600; padding: 0.75rem 2rem; border-radius: 0.75rem; display: flex; align-items: center; gap: 0.5rem; cursor: pointer;">
                    <i class="fas fa-save"></i> Enregistrer
                </button>
            </div>
        </div>
    </div>

    <!-- Beautiful Custom Confirm Delete Modal -->
    <div id="customConfirmOverlay" class="modal-overlay" onclick="closeCustomConfirmModalOuter(event)">
        <div class="modal"
            style="max-width: 400px; border-radius: 1.5rem; background: var(--bg-secondary); border: 1px solid var(--border-color); box-shadow: var(--shadow-2xl); padding: 2rem; text-align: center;">
            <div id="customConfirmIconContainer"
                style="width: 60px; height: 60px; border-radius: 50%; background: rgba(239, 68, 68, 0.1); color: var(--red-500); display: flex; align-items: center; justify-content: center; margin: 0 auto 1.5rem; font-size: 1.8rem;">
                <i id="customConfirmIcon" class="fas fa-exclamation-triangle"></i>
            </div>

            <h3 id="customConfirmTitle"
                style="margin: 0 0 0.75rem; font-size: 1.3rem; font-weight: 700; color: var(--text-primary);">
                Supprimer l'Intervention
            </h3>

            <p id="customConfirmDesc"
                style="margin: 0 0 2rem; font-size: 0.95rem; color: var(--text-muted); line-height: 1.5;">
                Voulez-vous vraiment supprimer définitivement cette intervention ? Cette action est irréversible.
            </p>

            <div style="display: flex; gap: 1rem; justify-content: center;">
                <button class="btn" onclick="closeCustomConfirmModal()"
                    style="background: var(--bg-secondary); border: 2px solid var(--border-color); color: var(--text-primary); font-weight: 600; padding: 0.75rem 1.5rem; border-radius: 0.75rem; cursor: pointer; flex: 1;">
                    Annuler
                </button>
                <button class="btn" id="customConfirmYesBtn"
                    style="background: var(--gradient-orange-red); border: none; color: white; font-weight: 600; padding: 0.75rem 1.5rem; border-radius: 0.75rem; cursor: pointer; flex: 1;">
                    Supprimer
                </button>
            </div>
        </div>
    </div>

    <!-- Beautiful Custom Login Modal -->
    <div id="customLoginOverlay" class="modal-overlay" onclick="closeCustomLoginModalOuter(event)">
        <div class="modal login-modal-card">
            <button type="button" class="login-modal-close" onclick="closeCustomLoginModal()" title="Fermer">
                <i class="fas fa-times"></i>
            </button>

            <div class="login-modal-hero">
                <div class="login-modal-icon">
                    <i class="fas fa-user-shield"></i>
                </div>
                <h3>Connexion Espace IT</h3>
                <p>Accedez a votre espace securise LABO-IT CONTROL.</p>
            </div>

            <form id="loginForm" class="login-form" onsubmit="handleLoginSubmit(event)">
                <div class="login-field">
                    <label for="loginEmail">Adresse Email</label>
                    <div class="login-input-shell">
                        <i class="fas fa-envelope"></i>
                        <input type="email" id="loginEmail" placeholder="Ex: admin@nedjma.dz" autocomplete="username"
                            required>
                    </div>
                </div>

                <div class="login-field">
                    <label for="loginPassword">Mot de passe</label>
                    <div class="login-input-shell">
                        <i class="fas fa-lock"></i>
                        <input type="password" id="loginPassword" placeholder="Mot de passe"
                            autocomplete="current-password" required>
                    </div>
                </div>

                <div class="login-actions">
                    <button type="button" class="login-btn-secondary" onclick="closeCustomLoginModal()">
                        Annuler
                    </button>
                    <button type="submit" class="login-btn-primary">
                        <i class="fas fa-right-to-bracket"></i>
                        <span>Se connecter</span>
                    </button>
                </div>
            </form>
        </div>
    </div>

    <!-- Beautiful KPI Details Popup Modal -->
    <div id="kpiDetailsOverlay" class="modal-overlay" onclick="closeKpiDetailsModalOuter(event)">
        <div class="modal"
            style="max-width: 680px; border-radius: 1.5rem; background: var(--bg-secondary); border: 1px solid var(--border-color); box-shadow: var(--shadow-2xl); padding: 2rem; position: relative;">
            <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1.5rem;">
                <h3 id="kpiDetailsTitle"
                    style="margin: 0; font-size: 1.4rem; font-weight: 700; background: var(--gradient-blue-purple); -webkit-background-clip: text; -webkit-text-fill-color: transparent; display: flex; align-items: center; gap: 0.5rem; background-clip: text;">
                    <i class="fas fa-list-ul"></i> Détails
                </h3>
                <button onclick="closeKpiDetailsModal()"
                    style="background: none; border: none; color: var(--text-muted); font-size: 1.2rem; cursor: pointer;">
                    <i class="fas fa-times"></i>
                </button>
            </div>

            <div style="max-height: 400px; overflow-y: auto; margin-bottom: 1.5rem; padding-right: 0.5rem;"
                id="kpiDetailsContent">
                <!-- Content injected dynamically -->
            </div>

            <div style="display: flex; justify-content: flex-end;">
                <button class="btn btn-primary" onclick="closeKpiDetailsModal()"
                    style="background: var(--gradient-blue-purple); border: none; color: white; font-weight: 600; padding: 0.75rem 2rem; border-radius: 0.75rem; cursor: pointer;">
                    Fermer
                </button>
            </div>
        </div>
    </div>

    <!-- Beautiful Cache Cleaning Real-time Progress Modal -->
    <div id="cacheCleanOverlay" class="modal-overlay cache-clean-overlay">
        <div class="modal cache-clean-modal">

            <div class="cache-clean-header">
                <div class="cache-clean-icon">
                    <i class="fas fa-trash-alt" id="cacheCleanModalIcon"></i>
                </div>
                <h3>
                    Nettoyage du Cache Système 2.2.0
                </h3>
                <p>
                    Exécution des tâches de maintenance en temps réel...
                </p>
            </div>

            <!-- Beautiful Progress Bar -->
            <div class="cache-clean-progress">
                <div id="cacheCleanProgressBar">
                </div>
            </div>

            <!-- Live Operations Log -->
            <div id="cacheCleanLog" class="cache-clean-log">
                <!-- Logs will be appended here in real-time -->
            </div>

            <div class="cache-clean-footer" id="cacheCleanFooter">
                <i class="fas fa-spinner fa-spin"></i> Traitement en cours...
            </div>
        </div>
    </div>

    <!-- ============ خفة تحرْة احترافة ============ -->
    <div class="background-container">
        <div class="tech-grid"></div>
        <div class="glow-lines"></div>
        <div class="orb orb-1"></div>
        <div class="orb orb-2"></div>
        <div class="orb orb-3"></div>
        <div class="orb orb-4"></div>
        <div class="orb orb-5"></div>
        <div class="particles" id="particlesContainer"></div>
    </div>

    <div class="container">
        <!-- شرط اتاعااثابت -->
        <nav class="top-nav">
            <div class="logo-section" style="cursor: pointer;" onclick="showView('dashboardView')"
                title="Retour au Tableau de Bord">
                <div class="logo-icon-wrapper">
                    <i class="fas fa-microchip"></i>
                </div>
                <div class="logo-text">
                    <div style="display: flex; align-items: center; gap: 0.4rem;">
                        <h2>LABO-IT CONTROL</h2>

                        <!-- Boutons d'informations (Entreprise / Développeur / Paramètres) -->
                        <div class="header-info-buttons">
                            <button class="info-btn company-btn" onclick="event.stopPropagation(); openCompanyModal()"
                                title="Détails de l'Entreprise (LABO NEDJMA)">
                                <i class="fas fa-building"></i>
                            </button>
                            <button class="info-btn developer-btn" onclick="event.stopPropagation(); openDevModal()"
                                title="Détails du Développeur (Billel Bouraba)">
                                <i class="fas fa-code"></i>
                            </button>
                            <button class="info-btn settings-btn" onclick="event.stopPropagation(); openSettingsModal()"
                                title="Paramètres du Système">
                                <i class="fas fa-cog"></i>
                            </button>
                        </div>
                    </div>
                    <span>GESTION LABORATOIRE INFORMATIQUE</span>
                </div>
            </div>

            <!-- Logo Central Professionnel -->
            <div class="top-nav-middle-logo" onclick="showView('dashboardView')" title="Tableau de Bord">
                <div class="logo-container">
                    <div class="logo-top-line"></div>
                    <div class="logo-main-text">
                        <span class="logo-char-l">L</span>
                        <span class="logo-star-wrapper">
                            <svg viewBox="85 15 75 80" class="logo-star-svg">
                                <path
                                    d="M 148,22 C 141,43 135,48 130,54 C 135,60 142,65 147,73 C 135,68 129,64 123,62 C 115,72 109,80 102,88 C 109,72 112,64 115,54 C 105,50 95,48 89,45 C 105,43 112,43 119,45 C 129,36 139,28 148,22 Z" />
                            </svg>
                        </span>
                        <span class="logo-text-right">BONEDJMA</span>
                    </div>
                    <div class="logo-subtitle">LABORATOIRES COSMÉTIQUES</div>
                    <div class="logo-bottom-line"></div>
                </div>
            </div>

            <div class="nav-actions">
                <!-- État de Besoins / Achats Dropdown -->
                <div class="nav-besoin-dropdown" id="besoinDropdown">
                    <button class="nav-besoin-btn" onclick="toggleBesoinDropdown(event)"
                        title="État de Besoins mandes d'Achat IT">
                        <i class="fas fa-shopping-cart"></i>
                        <span>Besoins IT</span>
                        <span class="besoin-count-badge" id="besoinCountBadge">0</span>
                        <i class="fas fa-chevron-down besoin-chevron"></i>
                    </button>
                    <div class="besoin-dropdown-menu" id="besoinDropdownMenu">
                        <button class="besoin-dropdown-item" onclick="navigateBesoinTab('demandes')">
                            <i class="fas fa-file-invoice" style="color: #ec4899;"></i>
                            <span>Demandes d'Achat</span>
                            <span class="besoin-menu-count" id="besoinDemandesCount">0</span>
                        </button>
                        <button class="besoin-dropdown-item" onclick="navigateBesoinTab('envois')">
                            <i class="fas fa-paper-plane" style="color: #3b82f6;"></i>
                            <span>Confirmations d'Envoi</span>
                            <span class="besoin-menu-count" id="besoinEnvoisCount">0</span>
                        </button>
                        <button class="besoin-dropdown-item" onclick="navigateBesoinTab('pannes')">
                            <i class="fas fa-tools" style="color: #f59e0b;"></i>
                            <span>Fiches de Panne</span>
                            <span class="besoin-menu-count" id="besoinPannesCount">0</span>
                        </button>
                    </div>
                </div>

                <!-- Authenticated / Login Area -->
                <div id="authArea" style="display: flex; align-items: center; gap: 0.8rem;">
                    <!-- Dynamically populated via JS -->
                </div>
            </div>
        </nav>

        <!-- Dashboard View -->
        <div id="dashboardView" class="view-container view-active">

            <!-- احتÈÉ ارئس>
            <div class="main-content">
                <!-- اإحصائات -->
                <div class="stats-row" id="statsRow">
                    <div class="stat-card" style="cursor: pointer;" onclick="showKpiDetails('total')">
                        <div class="stat-icon-wrapper"><i class="fas fa-laptop"></i></div>
                        <div class="stat-info">
                            <div class="stat-value" id="statTotal">42</div>
                            <div class="stat-label">Total Appareils</div>
                            <div class="stat-change" id="statTotalChange"><i class="fas fa-database"></i> Données live</div>
                        </div>
                    </div>
                    <div class="stat-card" style="cursor: pointer;" onclick="showKpiDetails('laptop')">
                        <div class="stat-icon-wrapper"><i class="fas fa-laptop"></i></div>
                        <div class="stat-info">
                            <div class="stat-value" id="statPC">28</div>
                            <div class="stat-label">PC Laptop</div>
                            <div class="stat-change" id="statPCChange"><i class="fas fa-chart-pie"></i> Aucune donnée</div>
                        </div>
                    </div>
                    <div class="stat-card" style="cursor: pointer;" onclick="showKpiDetails('maintenance')">
                        <div class="stat-icon-wrapper"><i class="fas fa-tools"></i></div>
                        <div class="stat-info">
                            <div class="stat-value" id="statMaint">5</div>
                            <div class="stat-label">En Maintenance</div>
                            <div class="stat-change" id="statMaintChange"><i class="fas fa-chart-pie"></i> Aucune donnée</div>
                        </div>
                    </div>
                    <div class="stat-card" style="cursor: pointer;" onclick="showKpiDetails('stock')">
                        <div class="stat-icon-wrapper"><i class="fas fa-boxes"></i></div>
                        <div class="stat-info">
                            <div class="stat-value" id="statStock">9</div>
                            <div class="stat-label">En Stock</div>
                            <div class="stat-change" id="statStockChange"><i class="fas fa-boxes-stacked"></i> Aucune donnée</div>
                        </div>
                    </div>
                    <div class="stat-card" style="cursor: pointer;" onclick="showKpiDetails('printer')">
                        <div class="stat-icon-wrapper"><i class="fas fa-print"></i></div>
                        <div class="stat-info">
                            <div class="stat-value" id="statPrint">6</div>
                            <div class="stat-label">Imprimantes</div>
                            <div class="stat-change" id="statPrintChange"><i class="fas fa-chart-pie"></i> Aucune donnée</div>
                        </div>
                    </div>
                    <div class="stat-card" style="cursor: pointer;" onclick="showView('mobilesView')">
                        <div class="stat-icon-wrapper"><i class="fas fa-mobile-screen-button"></i></div>
                        <div class="stat-info">
                            <div class="stat-value" id="statMobile">0</div>
                            <div class="stat-label">Mobiles & PDA</div>
                            <div class="stat-change" id="statMobileChange"><i class="fas fa-chart-pie"></i> Aucune donnee</div>
                        </div>
                    </div>
                    <div class="stat-card" style="cursor: pointer;" onclick="showKpiDetails('desktop')">
                        <div class="stat-icon-wrapper"><i class="fas fa-computer"></i></div>
                        <div class="stat-info">
                            <div class="stat-value" id="statDesktop">12</div>
                            <div class="stat-label">PC Bureau</div>
                            <div class="stat-change" id="statDesktopChange"><i class="fas fa-chart-pie"></i> Aucune donnée</div>
                        </div>
                    </div>
                </div>

                <!-- اÈحدات اسرعة -->
                <div class="section-header">
                    <div class="section-title">
                        <i class="fas fa-th-large"></i> Modules Rapides
                    </div>
                </div>
                <div class="modules-grid">
                    <div class="module-card" onclick="showView('inventaireView')">
                        <div class="module-icon"><i class="fas fa-laptop-medical"></i></div>
                        <span class="module-badge badge-blue" id="moduleDeviceBadge">42 Appareils</span>
                        <h4>Inventaire</h4>
                        <p>Gestion des ordinateurs portables, de bureau et accessoires.</p>
                        <button class="module-btn">Accéder <i class="fas fa-arrow-right"></i></button>
                    </div>
                    <div class="module-card" onclick="showView('imprimantesView')">
                        <div class="module-icon"><i class="fas fa-print"></i></div>
                        <span class="module-badge badge-purple" id="modulePrinterBadge">6 Imprimantes</span>
                        <h4>Imprimantes</h4>
                        <p>Gestion complète du parc d'impression et maintenance.</p>
                        <button class="module-btn">Gérer <i class="fas fa-cog"></i></button>
                    </div>
                    <div class="module-card" onclick="showView('mobilesView')">
                        <div class="module-icon"><i class="fas fa-mobile-screen-button"></i></div>
                        <span class="module-badge badge-indigo" id="moduleMobileBadge">0 Mobiles</span>
                        <h4>Téléphones & PDA</h4>
                        <p>Inventaire des téléphones, tablettes, PDA, cartes SIM et fiches de décharge.</p>
                        <button class="module-btn">Ouvrir <i class="fas fa-arrow-right"></i></button>
                    </div>
                    <div class="module-card" onclick="showView('stockView')">
                        <div class="module-icon"><i class="fas fa-warehouse"></i></div>
                        <span class="module-badge badge-cyan" id="moduleStockBadge">9 Pièces</span>
                        <h4>Stock</h4>
                        <p>Consommables, pièces de rechange et nouveau matériel.</p>
                        <button class="module-btn">Parcourir <i class="fas fa-eye"></i></button>
                    </div>
                    <div class="module-card" onclick="showView('distributionView')">
                        <div class="module-icon"><i class="fas fa-hand-holding"></i></div>
                        <span class="module-badge badge-teal" id="moduleDistributionBadge">Suivi</span>
                        <h4>Distribution & Prêt</h4>
                        <p>Distribution de matériel et prêts aux employés.</p>
                        <button class="module-btn">Gérer <i class="fas fa-arrow-right"></i></button>
                    </div>
                </div>

                <div class="dashboard-analytics" id="dashboardAnalytics">
                    <section class="analytics-panel analytics-main-panel">
                        <div class="analytics-panel-header">
                            <div>
                                <span class="analytics-eyebrow">Pilotage IT</span>
                                <h3>Vue analytique du parc</h3>
                            </div>
                            <span class="analytics-status-pill"><i class="fas fa-signal"></i> Données live</span>
                        </div>

                        <div class="analytics-signal-board">
                            <article class="analytics-signal signal-blue">
                                <div class="signal-icon"><i class="fas fa-chart-line"></i></div>
                                <div>
                                    <span class="kpi-label">Disponibilité du parc</span>
                                    <strong id="analyticsHealthValue">0%</strong>
                                    <small id="analyticsHealthSub">0 / 0 actifs</small>
                                </div>
                            </article>
                            <article class="analytics-signal signal-amber">
                                <div class="signal-icon"><i class="fas fa-screwdriver-wrench"></i></div>
                                <div>
                                    <span class="kpi-label">Actions à suivre</span>
                                    <strong id="analyticsMaintValue">0</strong>
                                    <small id="analyticsMaintSub">0% du parc</small>
                                </div>
                            </article>
                            <article class="analytics-signal signal-emerald">
                                <div class="signal-icon"><i class="fas fa-layer-group"></i></div>
                                <div>
                                    <span class="kpi-label">Couverture stock</span>
                                    <strong id="analyticsStockValue">0</strong>
                                    <small id="analyticsStockSub">0 catégories</small>
                                </div>
                            </article>
                            <article class="analytics-signal signal-rose">
                                <div class="signal-icon"><i class="fas fa-handshake-angle"></i></div>
                                <div>
                                    <span class="kpi-label">Flux utilisateurs</span>
                                    <strong id="analyticsLoanValue">0</strong>
                                    <small id="analyticsLoanSub">0 opérations</small>
                                </div>
                            </article>
                        </div>

                        <div class="operations-grid">
                            <div class="operation-card">
                                <span>Portables</span>
                                <strong id="dashboardLaptopCount">0</strong>
                                <div class="mini-progress"><span id="dashboardLaptopBar"></span></div>
                            </div>
                            <div class="operation-card">
                                <span>Bureaux</span>
                                <strong id="dashboardDesktopCount">0</strong>
                                <div class="mini-progress"><span id="dashboardDesktopBar"></span></div>
                            </div>
                            <div class="operation-card">
                                <span>Imprimantes</span>
                                <strong id="dashboardPrinterCount">0</strong>
                                <div class="mini-progress"><span id="dashboardPrinterBar"></span></div>
                            </div>
                            <div class="operation-card">
                                <span>Mobiles</span>
                                <strong id="dashboardMobileCount">0</strong>
                                <div class="mini-progress"><span id="dashboardMobileBar"></span></div>
                            </div>
                        </div>

                        <!-- Conseil d'utilisation du système -->
                        <div class="dynamic-advisory-box">
                            <div class="advisory-icon-wrapper">
                                <i class="fas fa-lightbulb"></i>
                            </div>
                            <div class="advisory-content">
                                <span class="advisory-title">Conseil d'utilisation</span>
                                <p id="dynamicAdvisoryText" class="advisory-text">Chargement du conseil du jour...</p>
                            </div>
                        </div>
                    </section>

                    <section class="analytics-panel chart-panel">
                        <div class="analytics-panel-header compact">
                            <div>
                                <span class="analytics-eyebrow">Répartition</span>
                                <h3>Charge par module</h3>
                            </div>
                        </div>
                        <div class="chart-bars" aria-label="Graphique de charge par module">
                            <div class="chart-item">
                                <div class="chart-track"><span class="chart-fill fill-blue" id="chartLaptops"></span>
                                </div>
                                <strong id="chartLaptopsValue">0</strong>
                                <small>Portables</small>
                            </div>
                            <div class="chart-item">
                                <div class="chart-track"><span class="chart-fill fill-purple" id="chartDesktops"></span>
                                </div>
                                <strong id="chartDesktopsValue">0</strong>
                                <small>Bureaux</small>
                            </div>
                            <div class="chart-item">
                                <div class="chart-track"><span class="chart-fill fill-cyan" id="chartPrinters"></span>
                                </div>
                                <strong id="chartPrintersValue">0</strong>
                                <small>Print</small>
                            </div>
                            <div class="chart-item">
                                <div class="chart-track"><span class="chart-fill fill-rose"
                                        id="chartMobiles"></span></div>
                                <strong id="chartMobilesValue">0</strong>
                                <small>Mobiles</small>
                            </div>
                        </div>
                        <div class="status-ring-row">
                            <div class="status-ring" id="dashboardStatusRing">
                                <span id="dashboardStatusRingValue">0</span>
                            </div>
                            <div class="status-ring-legend">
                                <span><i class="legend-dot dot-active"></i><strong id="dashboardStatusActive">0</strong>
                                    actifs</span>
                                <span><i class="legend-dot dot-maint"></i><strong
                                        id="dashboardStatusMaintenance">0</strong> maintenance</span>
                                <span><i class="legend-dot dot-stock"></i><strong id="dashboardStatusStock">0</strong>
                                    stock</span>
                            </div>
                        </div>
                    </section>
                </div>

                <!-- جدÈاأجزة -->
                <div class="data-table-wrapper" id="mainTableWrapper">
                    <div class="table-header">
                        <div class="table-title">
                            <i class="fas fa-table"></i> Appareils Récemment Enregistrés
                        </div>
                        <div class="table-actions">
                            <div class="table-search-field">
                                <i class="fas fa-search"></i>
                                <input type="text" placeholder="Recherche rapide..." id="searchInput"
                                    oninput="filterTable()"
                                    onfocus="this.parentElement.style.borderColor='var(--blue-500)'; this.parentElement.style.boxShadow='0 0 0 3px rgba(59,130,246,0.1)';"
                                    onblur="this.parentElement.style.borderColor='var(--border-color)'; this.parentElement.style.boxShadow='none';">
                            </div>
                        </div>
                    </div>
                    <div class="table-responsive">
                        <table class="inventory-table">
                            <thead>
                                <tr>
                                    <th>Utilisateur</th>
                                    <th>Appareil</th>
                                    <th>Modèle</th>
                                    <th>Statut</th>
                                    <th>Emplacement</th>
                                    <th>Actions</th>
                                </tr>
                            </thead>
                            <tbody id="tableBody">
                                <!-- Rempli par JavaScript -->
                            </tbody>
                        </table>
                    </div>
                    <!-- Devices pagination switcher -->
                    <div id="devicesPagination" class="pagination-container"></div>
                </div>
            </div>
        </div>

        <!-- Inventaire Detailed View -->
        <div id="inventaireView" class="view-container">
            <div class="view-header inventory-toolbar">
                <div class="view-title-box">
                    <div class="view-icon"><i class="fas fa-laptop-medical"></i></div>
                    <div class="view-title-text">
                        <h2>Inventaire Détaillé</h2>
                        <p>Gestion complète de tous les équipements du laboratoire.</p>
                    </div>
                </div>
                <div class="view-toolbar-actions">
                    <button class="back-btn header-back-btn inventory-back-btn" onclick="showView('dashboardView')" title="Retour au Tableau de Bord" aria-label="Retour au Tableau de Bord">
                        <i class="fas fa-arrow-left"></i>
                    </button>
                    <button class="btn btn-primary" onclick="openAddModal()">
                        <i class="fas fa-plus"></i> Nouvel équipement
                    </button>
                </div>
            </div>
            <!-- Cards for ACTIV and MAINTENANCE stats -->
            <div class="modules-grid"
                style="margin-bottom: 2rem; grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));">
                <div class="stat-card dist-card-total" onclick="filterInventaireByStatus('Total')"
                    style="cursor: pointer;" title="Afficher tous les appareils">
                    <div class="stat-icon-wrapper"><i class="fas fa-layer-group"></i></div>
                    <div class="stat-info">
                        <div class="stat-value" id="inventaireTotalCount">0</div>
                        <div class="stat-label">Tous les Appareils</div>
                    </div>
                </div>
                <div class="stat-card dist-card-returned" onclick="filterInventaireByStatus('Actif')"
                    style="cursor: pointer;" title="Filtrer par appareils actifs">
                    <div class="stat-icon-wrapper"><i class="fas fa-check-circle"></i></div>
                    <div class="stat-info">
                        <div class="stat-value" id="inventaireActiveCount">0</div>
                        <div class="stat-label">Appareils Actifs</div>
                    </div>
                </div>
                <div class="stat-card dist-card-active" onclick="filterInventaireByStatus('Maintenance')"
                    style="cursor: pointer;" title="Filtrer par appareils en maintenance">
                    <div class="stat-icon-wrapper"><i class="fas fa-tools"></i></div>
                    <div class="stat-info">
                        <div class="stat-value" id="inventaireMaintCount">0</div>
                        <div class="stat-label">En Maintenance</div>
                    </div>
                </div>
            </div>
            <!-- Here we could have a more advanced table or filters -->
            <div id="inventaireTableContainer">
                <!-- Re-using the main table for now -->
            </div>
        </div>

        <!-- Imprimantes View -->
        <div id="imprimantesView" class="view-container">
            <div class="view-header printers-toolbar">
                <div class="view-title-box">
                    <div class="view-icon" style="background: var(--gradient-pink-orange);"><i class="fas fa-print"></i>
                    </div>
                    <div class="view-title-text">
                        <h2>Gestion des Imprimantes</h2>
                        <p>Suivi de l'État, consommables et maintenance du parc d'impression.</p>
                    </div>
                </div>
                <div class="view-toolbar-actions">
                    <button class="back-btn header-back-btn printers-back-btn" onclick="showView('dashboardView')" title="Retour au Tableau de Bord" aria-label="Retour au Tableau de Bord">
                        <i class="fas fa-arrow-left"></i>
                    </button>
                    <button class="btn btn-primary" onclick="openNewPrinterForm()"
                        style="background: var(--gradient-pink-orange); border: none;">
                        <i class="fas fa-plus"></i> Nouvelle Imprimante
                    </button>
                </div>
            </div>
            <div class="modules-grid"
                style="margin-bottom: 2rem; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));">
                <!-- Special printer status cards -->
                <div class="stat-card dist-card-total" onclick="filterPrintersByStatus('Total')"
                    style="cursor: pointer;" title="Afficher toutes les imprimantes">
                    <div class="stat-icon-wrapper"><i class="fas fa-layer-group"></i></div>
                    <div class="stat-info">
                        <div class="stat-value" id="printerTotalCount">0</div>
                        <div class="stat-label">Toutes Imprimantes</div>
                    </div>
                </div>
                <div class="stat-card printer-card-online" onclick="filterPrintersByStatus('Actif')"
                    style="cursor: pointer;" title="Filtrer par imprimantes en ligne">
                    <div class="stat-icon-wrapper"><i class="fas fa-check-circle"></i></div>
                    <div class="stat-info">
                        <div class="stat-value" id="printerOnlineCount">0</div>
                        <div class="stat-label">En Ligne</div>
                    </div>
                </div>
                <div class="stat-card dist-card-active" onclick="filterPrintersByStatus('Maintenance')"
                    style="cursor: pointer;" title="Filtrer par imprimantes en maintenance">
                    <div class="stat-icon-wrapper"><i class="fas fa-tools"></i></div>
                    <div class="stat-info">
                        <div class="stat-value" id="printerMaintCount">0</div>
                        <div class="stat-label">En Maintenance</div>
                    </div>
                </div>
                <div class="stat-card printer-card-offline" onclick="filterPrintersByStatus('Hors Ligne')"
                    style="cursor: pointer;" title="Filtrer par imprimantes hors ligne">
                    <div class="stat-icon-wrapper"><i class="fas fa-exclamation-triangle"></i></div>
                    <div class="stat-info">
                        <div class="stat-value" id="printerOfflineCount">0</div>
                        <div class="stat-label">Hors Ligne</div>
                    </div>
                </div>
            </div>
            <div class="data-table-wrapper">
                <div class="table-header"
                    style="display: flex; justify-content: space-between; align-items: center; gap: 1rem; flex-wrap: wrap;">
                    <h3 style="margin: 0; font-size: 1.2rem; font-weight: 600; color: var(--text-primary);">Liste des
                        Imprimantes</h3>
                    <div class="table-actions">
                        <div class="table-search-field module-search-field">
                            <i class="fas fa-search"></i>
                            <input type="text" placeholder="Recherche rapide..." id="printerSearchInput"
                                oninput="filterPrintersTable()"
                                onfocus="this.parentElement.style.borderColor='var(--blue-500)'; this.parentElement.style.boxShadow='0 0 0 3px rgba(59,130,246,0.1)';"
                                onblur="this.parentElement.style.borderColor='var(--border-color)'; this.parentElement.style.boxShadow='none';">
                        </div>
                    </div>
                </div>
                <div class="table-responsive">
                    <table class="printers-table">
                        <thead>
                            <tr>
                                <th>Modèle</th>
                                <th>Emplacement</th>
                                <th>Statut Toner</th>
                                <th>Dernière Maintenance</th>
                                <th style="width: 100px; text-align: center;">Actions</th>
                            </tr>
                        </thead>
                        <tbody id="printersTableBody">
                            <!-- Populated dynamically via JavaScript -->
                        </tbody>
                    </table>
                </div>
                <!-- Printers pagination switcher -->
                <div id="printersPagination" class="pagination-container"></div>
            </div>
        </div>

        <!-- Stock View -->
        <div id="stockView" class="view-container">
            <div class="view-header stock-toolbar">
                <div class="view-title-box">
                    <div class="view-icon" style="background: var(--gradient-cyan-blue);"><i
                            class="fas fa-warehouse"></i></div>
                    <div class="view-title-text">
                        <h2>Gestion du Stock</h2>
                        <p>Inventaire des composants, câblage & matériel de rechange.</p>
                    </div>
                </div>
                <div class="view-toolbar-actions">
                    <button class="back-btn header-back-btn stock-back-btn" onclick="showView('dashboardView')" title="Retour au Tableau de Bord" aria-label="Retour au Tableau de Bord">
                        <i class="fas fa-arrow-left"></i>
                    </button>
                    <button class="btn btn-primary" onclick="openAddStockFormGeneric()"
                        style="background: var(--gradient-cyan-blue); border: none;">
                        <i class="fas fa-plus"></i> Ajouter au Stock
                    </button>
                </div>
            </div>
            <div class="modules-grid" style="grid-template-columns: repeat(auto-fit, minmax(240px, 1fr)); gap: 1.5rem;">
                <div class="stat-card dist-card dist-card-total" onclick="openCategoryDetail('RAM & SSD')"
                    style="cursor: pointer;">
                    <div class="stat-icon-wrapper"><i class="fas fa-memory"></i></div>
                    <div class="stat-info">
                        <div class="stat-value" style="font-size: 1.1rem; margin-bottom: 0.2rem;">RAM & SSD</div>
                        <div class="stat-label" id="stockCount_RAM_SSD"
                            style="text-transform: none; letter-spacing: normal;">12 unités disponibles</div>
                    </div>
                </div>
                <div class="stat-card dist-card dist-card-purple" onclick="openCategoryDetail('Périphériques')"
                    style="cursor: pointer;">
                    <div class="stat-icon-wrapper"><i class="fas fa-mouse"></i></div>
                    <div class="stat-info">
                        <div class="stat-value" style="font-size: 1.1rem; margin-bottom: 0.2rem;">Périphériques</div>
                        <div class="stat-label" id="stockCount_Peripheriques"
                            style="text-transform: none; letter-spacing: normal;">45 unités disponibles</div>
                    </div>
                </div>
                <div class="stat-card dist-card dist-card-cyan" onclick="openCategoryDetail('Câblage & Réseau')"
                    style="cursor: pointer;">
                    <div class="stat-icon-wrapper"><i class="fas fa-network-wired"></i></div>
                    <div class="stat-info">
                        <div class="stat-value" style="font-size: 1.1rem; margin-bottom: 0.2rem;">Câblage & Réseau</div>
                        <div class="stat-label" id="stockCount_Cablage_Reseau"
                            style="text-transform: none; letter-spacing: normal;">80 mètres disponibles</div>
                    </div>
                </div>
                <div class="stat-card dist-card dist-card-returned" onclick="openCategoryDetail('Écrans & Moniteurs')"
                    style="cursor: pointer;">
                    <div class="stat-icon-wrapper"><i class="fas fa-desktop"></i></div>
                    <div class="stat-info">
                        <div class="stat-value" style="font-size: 1.1rem; margin-bottom: 0.2rem;">Écrans & Moniteurs
                        </div>
                        <div class="stat-label" id="stockCount_Ecrans_Moniteurs"
                            style="text-transform: none; letter-spacing: normal;">15 unités disponibles</div>
                    </div>
                </div>
                <div class="stat-card dist-card dist-card-active" onclick="openCategoryDetail('PC Portables (Laptops)')"
                    style="cursor: pointer;">
                    <div class="stat-icon-wrapper"><i class="fas fa-laptop"></i></div>
                    <div class="stat-info">
                        <div class="stat-value" style="font-size: 1.1rem; margin-bottom: 0.2rem;">PC Portables</div>
                        <div class="stat-label" id="stockCount_PC_Portables"
                            style="text-transform: none; letter-spacing: normal;">8 unités disponibles</div>
                    </div>
                </div>
                <div class="stat-card dist-card dist-card-mobile" onclick="openCategoryDetail('Téléphones & PDA')"
                    style="cursor: pointer;">
                    <div class="stat-icon-wrapper"><i class="fas fa-mobile-screen-button"></i></div>
                    <div class="stat-info">
                        <div class="stat-value" style="font-size: 1.1rem; margin-bottom: 0.2rem;">Téléphones & PDA</div>
                        <div class="stat-label" id="stockCount_Telephones_PDA"
                            style="text-transform: none; letter-spacing: normal;">0 unités disponibles</div>
                    </div>
                </div>
                <div class="stat-card dist-card dist-card-indigo" onclick="openCategoryDetail('PC Bureau (Desktops)')"
                    style="cursor: pointer;">
                    <div class="stat-icon-wrapper"><i class="fas fa-server"></i></div>
                    <div class="stat-info">
                        <div class="stat-value" style="font-size: 1.1rem; margin-bottom: 0.2rem;">PC Bureau</div>
                        <div class="stat-label" id="stockCount_PC_Bureau"
                            style="text-transform: none; letter-spacing: normal;">5 unités disponibles</div>
                    </div>
                </div>
                <div class="stat-card dist-card dist-card-pink" onclick="openCategoryDetail('Accessoires Divers')"
                    style="cursor: pointer;">
                    <div class="stat-icon-wrapper"><i class="fas fa-keyboard"></i></div>
                    <div class="stat-info">
                        <div class="stat-value" style="font-size: 1.1rem; margin-bottom: 0.2rem;">Accessoires</div>
                        <div class="stat-label" id="stockCount_Accessoires_Divers"
                            style="text-transform: none; letter-spacing: normal;">24 unités disponibles</div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Stock Category Detail View -->
        <div id="stockCategoryDetailView" class="view-container">
            <div class="view-header stock-category-toolbar">
                <div class="view-title-box">
                    <div class="view-icon" id="catDetailIcon" style="background: var(--gradient-cyan-blue);">
                        <i class="fas fa-memory"></i>
                    </div>
                    <div class="view-title-text">
                        <h2 id="catDetailTitle">RAM & SSD</h2>
