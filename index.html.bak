                    <h3 class="dev-name">Billel Bouraba</h3>
                    <div class="dev-title-tags">
                        <span class="dev-tag tag-green">FULL-STACK DEVELOPER</span>
                        <span class="dev-tag tag-blue">IT ARCHITECT</span>
                    </div>
                </div>

                <!-- Contenu Profil -->
                <div class="dev-profile-content">
                    <div class="dev-section">
                        <div class="dev-section-title">
                            <i class="fas fa-quote-left"></i>
                            <span>MA MISSION</span>
                        </div>
                        <p class="dev-mission-text">
                            Passionné par l'innovation numérique et la performance IT, je conçois des solutions
                            logicielles avancées pour optimiser la gestion des parcs informatiques. Mon objectif est
                            d'allier ergonomie moderne et puissance technique.
                        </p>
                    </div>

                    <div class="dev-section">
                        <div class="dev-section-title">
                            <i class="fas fa-microchip"></i>
                            <span>EXPERTISE</span>
                        </div>
                        <div class="dev-expertise-badges">
                            <span class="expertise-badge">Node/React</span>
                            <span class="expertise-badge">UI/UX Design</span>
                            <span class="expertise-badge">Réseaux IT</span>
                        </div>
                    </div>

                    <div class="dev-social-actions"
                        style="display: flex; gap: 1rem; margin-top: 0.5rem; margin-bottom: 1.8rem; width: 100%;">
                        <a href="https://www.facebook.com/billel.bouraba/" target="_blank"
                            class="dev-social-card fb-card"
                            style="flex: 1; display: flex; align-items: center; gap: 0.8rem; background: rgba(37, 99, 235, 0.08); border: 1px solid rgba(37, 99, 235, 0.2); border-radius: 0.75rem; padding: 0.7rem 1.2rem; color: #60a5fa; text-decoration: none; font-weight: 600; font-size: 0.85rem; transition: all 0.3s ease; box-shadow: 0 4px 12px rgba(37, 99, 235, 0.05);">
                            <div
                                style="width: 32px; height: 32px; border-radius: 50%; background: #2563eb; color: white; display: flex; align-items: center; justify-content: center; font-size: 0.95rem; box-shadow: 0 0 10px rgba(37, 99, 235, 0.35); flex-shrink: 0;">
                                <i class="fab fa-facebook-f"></i>
                            </div>
                            <div
                                style="display: flex; flex-direction: column; align-items: flex-start; text-align: left;">
                                <span
                                    style="font-size: 0.7rem; color: #94a3b8; font-weight: 500; text-transform: uppercase; letter-spacing: 0.5px;">Facebook</span>
                                <span
                                    style="font-size: 0.82rem; color: #e2e8f0; font-weight: 700;">billel.bouraba</span>
                            </div>
                        </a>
                        <a href="https://wa.me/213550129402" target="_blank" class="dev-social-card wa-card"
                            style="flex: 1; display: flex; align-items: center; gap: 0.8rem; background: rgba(16, 185, 129, 0.08); border: 1px solid rgba(16, 185, 129, 0.2); border-radius: 0.75rem; padding: 0.7rem 1.2rem; color: #34d399; text-decoration: none; font-weight: 600; font-size: 0.85rem; transition: all 0.3s ease; box-shadow: 0 4px 12px rgba(16, 185, 129, 0.05);">
                            <div
                                style="width: 32px; height: 32px; border-radius: 50%; background: #10b981; color: white; display: flex; align-items: center; justify-content: center; font-size: 0.95rem; box-shadow: 0 0 10px rgba(16, 185, 129, 0.35); flex-shrink: 0;">
                                <i class="fab fa-whatsapp"></i>
                            </div>
                            <div
                                style="display: flex; flex-direction: column; align-items: flex-start; text-align: left;">
                                <span
                                    style="font-size: 0.7rem; color: #94a3b8; font-weight: 500; text-transform: uppercase; letter-spacing: 0.5px;">WhatsApp</span>
                                <span style="font-size: 0.82rem; color: #e2e8f0; font-weight: 700;">+213 550 12 94
                                    02</span>
                            </div>
                        </a>
                    </div>

                    <div class="dev-modal-footer">
                        <span class="footer-right">CO-DEVELOPED WITH CODING VIBE & ADVANCED AI TECHNOLOGIES</span>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Modal Paramètres Système -->
    <div id="settingsModal" class="custom-modal-overlay" onclick="closeSettingsModalOuter(event)">
        <div class="settings-modal-container">
            <button class="modal-close-btn" onclick="closeSettingsModal()" title="Fermer">
                <i class="fas fa-times"></i>
            </button>

            <div class="settings-modal-layout">
                <!-- Sidebar gauche: Onglets -->
                <div class="settings-sidebar">
                    <div class="settings-sidebar-header">
                        <i class="fas fa-sliders-h"></i>
                        <span>PARAMÈTRES</span>
                    </div>
                    <div class="settings-tabs-list">
                        <button id="setTab-general" class="settings-tab-btn active"
                            onclick="switchSettingsTab('general')">
                            <i class="fas fa-desktop"></i> Général
                        </button>
                        <button id="setTab-pdf" class="settings-tab-btn" onclick="switchSettingsTab('pdf')">
                            <i class="fas fa-file-pdf"></i> Impression PDF
                        </button>
                    </div>
                </div>

                <!-- Panneau droit: Contenu -->
                <div class="settings-content-area">
                    <!-- Onglet Général -->
                    <div id="settingsPane-general" class="settings-pane active">
                        <h3 class="settings-pane-title">️ Configuration de l'Interface</h3>
                        <p class="settings-pane-desc">Personnalisez le titre, le slogan et le comportement visuel
                            général de LABO-IT CONTROL.</p>

                        <div class="settings-form-group">
                            <label for="setAppName">Nom de l'application</label>
                            <input type="text" id="setAppName" placeholder="LABO-IT CONTROL" class="settings-input">
                            <small class="settings-input-help">Ce titre s'affiche dans le coin supérieur gauche de la
                                barre de navigation.</small>
                        </div>

                        <div class="settings-form-group">
                            <label for="setAppSlogan">Slogan de l'en-tête</label>
                            <input type="text" id="setAppSlogan" placeholder="GESTION LABORATOIRE INFORMATIQUE" class="settings-input">
                            <small class="settings-input-help">Ce slogan s'affiche juste en dessous du nom de
                                l'application.</small>
                        </div>

                        <div class="settings-form-group" style="margin-top: 1.2rem;">
                            <label for="setAccentPalette">Thème de Couleur d'Accent</label>
                            <select id="setAccentPalette" class="settings-input">
                                <option value="indigo">Royal Indigo (Bleu / Violet)</option>
                                <option value="emerald">Emerald Teal (Émeraude / Vert)</option>
                                <option value="rose">Sunset Rose (Rose / Orange)</option>
                                <option value="ocean">Ocean Breeze (Cyan / Bleu)</option>
                            </select>
                            <small class="settings-input-help">Modifiez instantanément la couleur principale de toute
                                l'application.</small>
                        </div>

                        <div class="settings-form-group"
                            style="display: flex; flex-direction: row; align-items: center; justify-content: space-between; gap: 1rem; border-top: 1px solid var(--border-color); padding-top: 1.2rem; margin-top: 1.2rem;">
                            <div>
                                <label
                                    style="margin-bottom: 0.2rem; display: block; font-weight: 600; color: var(--text-primary);">Effets
                                    de Lueur (Neon Glows)</label>
                                <small class="settings-input-help" style="margin: 0;">Activer les halos colorés animés
                                    au survol des cartes analytiques.</small>
                            </div>
                            <label class="switch-toggle"
                                style="position: relative; display: inline-block; width: 44px; height: 22px;">
                                <input type="checkbox" id="setNeonGlows" checked
                                    style="opacity: 0; width: 0; height: 0;">
                                <span class="slider-toggle"></span>
                            </label>
                        </div>

                        <div class="settings-form-group"
                            style="display: flex; flex-direction: row; align-items: center; justify-content: space-between; gap: 1rem; border-top: 1px solid var(--border-color); padding-top: 1.2rem; margin-top: 1.2rem;">
                            <div>
                                <label
                                    style="margin-bottom: 0.2rem; display: block; font-weight: 600; color: var(--text-primary);">Conseils
                                    de l'Assistant</label>
                                <small class="settings-input-help" style="margin: 0;">Afficher ou masquer la boîte de
                                    conseils du jour en bas du Tableau de Bord.</small>
                            </div>
                            <label class="switch-toggle"
                                style="position: relative; display: inline-block; width: 44px; height: 22px;">
                                <input type="checkbox" id="setShowAdvisory" checked
                                    style="opacity: 0; width: 0; height: 0;">
                                <span class="slider-toggle"></span>
                            </label>
                        </div>

                        <div class="settings-form-group"
                            style="display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 1rem; border-top: 1px solid var(--border-color); padding-top: 1.2rem; margin-top: 1.2rem;">
                            <div>
                                <label for="setStockThreshold">Seuil d'alerte stock</label>
                                <input type="number" id="setStockThreshold" min="1" max="99" value="5"
                                    class="settings-input">
                                <small class="settings-input-help">Notification quand le stock atteint
                                    <span id="stockThresholdVal">5 Pièces</span>.</small>
                            </div>
                            <div>
                                <label for="setLoanDuration">Durée de prêt par défaut</label>
                                <input type="number" id="setLoanDuration" min="1" max="365" value="30"
                                    class="settings-input">
                                <small class="settings-input-help">Nombre de jours utilisé pour les prêts et suivis.</small>
                            </div>
                        </div>

                        <div class="settings-form-group"
                            style="display: flex; flex-direction: row; align-items: center; justify-content: space-between; gap: 1rem; border-top: 1px solid var(--border-color); padding-top: 1.2rem; margin-top: 1.2rem;">
                            <div>
                                <label
                                    style="margin-bottom: 0.2rem; display: block; font-weight: 600; color: var(--text-primary);">Effets
                                    Sonores (Audio Chimes)</label>
                                <small class="settings-input-help" style="margin: 0;">Jouer un signal sonore cristallin
                                    en temps réel lors de l'affichage des notifications de succès ou d'erreur.</small>
                            </div>
                            <label class="switch-toggle"
                                style="position: relative; display: inline-block; width: 44px; height: 22px;">
                                <input type="checkbox" id="setSoundEffects" checked
                                    style="opacity: 0; width: 0; height: 0;">
                                <span class="slider-toggle"></span>
                            </label>
                        </div>

                        <div class="settings-form-group"
                            style="display: flex; flex-direction: row; align-items: center; justify-content: space-between; gap: 1rem; border-top: 1px solid var(--border-color); padding-top: 1.2rem; margin-top: 1.2rem;">
                            <div>
                                <label
                                    style="margin-bottom: 0.2rem; display: block; font-weight: 600; color: var(--text-primary);"><i
                                        class="fas fa-trash-alt" style="color: var(--red-500); margin-right: 5px;"></i>
                                    Maintenance du Cache 2.2.0</label>
                                <small class="settings-input-help" style="margin: 0;">Effacer le stockage local (cache
                                    de l'application) et forcer le rechargement complet pour appliquer les dernières
                                    mises à jour du système.</small>
                            </div>
                            <button class="btn" onclick="clearSystemCacheAndRestart()"
                                style="border: 2px solid var(--red-500); color: var(--red-500); padding: 0.6rem 1.2rem; font-size: 0.85rem; border-radius: 0.75rem; font-weight: 700; cursor: pointer; display: flex; align-items: center; gap: 0.5rem; transition: all 0.3s ease; background: none;"
                                onmouseover="this.style.background='rgba(239, 68, 68, 0.1)'"
                                onmouseout="this.style.background='none'">
                                <i class="fas fa-sync-alt"></i> Vider le Cache
                            </button>
                        </div>
                    </div>

                    <!-- Onglet Impression PDF -->
                    <div id="settingsPane-pdf" class="settings-pane">
                        <h3 class="settings-pane-title">Personnalisation des fiches PDF</h3>
                        <p class="settings-pane-desc">Modifiez les titres des blocs de signature en bas de la fiche
                            d'impression de besoins A4.</p>

                        <div class="settings-form-group">
                            <label for="setSig1">Signataire 1 (Gauche)</label>
                            <input type="text" id="setSig1" placeholder="Le Demandeur" class="settings-input">
                            <small class="settings-input-help">Généralement réservé à la personne qui déclare le
                                besoin.</small>
                        </div>

                        <div class="settings-form-group">
                            <label for="setSig2">Signataire 2 (Milieu)</label>
                            <input type="text" id="setSig2" placeholder="Le Responsable du service"
                                class="settings-input">
                            <small class="settings-input-help">Généralement réservé à la validation hiérarchique
                                directe.</small>
                        </div>

                        <div class="settings-form-group">
                            <label for="setSig3">Signataire 3 (Droite)</label>
                            <input type="text" id="setSig3" placeholder="ASSISTANTE MGX" class="settings-input">
                            <small class="settings-input-help">Généralement réservé aux services généraux ou
                                achats.</small>
                        </div>
                    </div>



                    <!-- Footer Options -->
                    <div class="settings-modal-footer"
                        style="display: flex; gap: 1rem; justify-content: flex-end; border-top: 1px solid var(--border-color); padding-top: 1.5rem; margin-top: 1.5rem;">
                        <button onclick="closeSettingsModal()" class="btn"
                            style="background: transparent; border: 1px solid var(--border-color); color: var(--text-primary); font-weight: 600; padding: 0.6rem 1.5rem; border-radius: 0.5rem; cursor: pointer; font-size: 0.9rem;">
                            Annuler
                        </button>
                        <button onclick="saveAppSettings()" class="btn"
                            style="background: var(--gradient-blue-purple); border: none; color: white; font-weight: 600; padding: 0.6rem 1.8rem; border-radius: 0.5rem; cursor: pointer; font-size: 0.9rem; display: flex; align-items: center; gap: 0.4rem;">
                            <i class="fas fa-save"></i> Enregistrer
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Firebase SDKs (Compat v10.8.0) -->
    <script src="https://www.gstatic.com/firebasejs/10.8.0/firebase-app-compat.js"></script>
    <script src="https://www.gstatic.com/firebasejs/10.8.0/firebase-auth-compat.js"></script>
    <script src="https://www.gstatic.com/firebasejs/10.8.0/firebase-firestore-compat.js"></script>
    <script src="https://www.gstatic.com/firebasejs/10.8.0/firebase-analytics-compat.js"></script>

    <script src="js/app.js?v=2.2.0"></script>

</body>

</html>
