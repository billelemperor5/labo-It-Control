                                <i class="fas fa-tag"></i>
                            </div>
                        </div>
                        <div class="premium-input-group">
                            <label>Catégorie</label>
                            <div class="premium-input-wrapper">
                                <select id="addStockCategory">
                                    <option value="RAM & SSD">RAM & SSD</option>
                                    <option value="Périphériques">Périphériques</option>
                                    <option value="Câblage & Réseau">Câblage & Réseau</option>
                                    <option value="Écrans & Moniteurs">Écrans & Moniteurs</option>
                                    <option value="PC Portables (Laptops)">PC Portables (Laptops)</option>
                                    <option value="Téléphones & PDA">Téléphones & PDA</option>
                                    <option value="PC Bureau (Desktops)">PC Bureau (Desktops)</option>
                                    <option value="Accessoires Divers">Accessoires Divers</option>
                                </select>
                                <i class="fas fa-layer-group"></i>
                            </div>
                        </div>
                        <div class="premium-input-group" style="margin-bottom: 0;">
                            <label>Numéro de Série / Référence</label>
                            <div class="premium-input-wrapper">
                                <input type="text" id="addStockRef" placeholder="Ex: REF-10293">
                                <i class="fas fa-barcode"></i>
                            </div>
                        </div>
                        <div class="premium-input-group" style="margin-bottom: 0;">
                            <label>Code RF Stock</label>
                            <div class="premium-input-wrapper stock-rf-input-wrapper">
                                <input type="text" id="addStockCode" placeholder="RF-STK-2026-0001">
                                <i class="fas fa-fingerprint"></i>
                                <button type="button" class="stock-rf-mini-btn" onclick="refreshStockCode()" title="Générer un nouveau code RF">
                                    <i class="fas fa-wand-magic-sparkles"></i>
                                </button>
                                <button type="button" class="stock-rf-mini-btn" onclick="copyStockCodeFromForm()" title="Copier le code RF">
                                    <i class="fas fa-copy"></i>
                                </button>
                            </div>
                            <small class="stock-rf-help">Code interne unique à écrire ou coller sur le produit.</small>
                        </div>
                    </div>

                    <!-- Section 2 -->
                    <div class="form-section-card">
                        <div class="form-section-title">
                            <i class="fas fa-layer-group"></i> Quantité & Stockage
                        </div>
                        <div class="premium-input-group">
                            <label>Quantité Entrante</label>
                            <div class="premium-input-wrapper">
                                <input type="number" id="addStockQty" min="1" placeholder="Ex: 10">
                                <i class="fas fa-sort-numeric-up"></i>
                            </div>
                        </div>
                        <div class="premium-input-group" style="margin-bottom: 0;">
                            <label>Emplacement (Rayon/Étagère)</label>
                            <div class="premium-input-wrapper">
