            <!-- Cards for Stock statistics -->
            <div class="modules-grid"
                style="margin-bottom: 2rem; grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));">
                <div class="stat-card dist-card-total" onclick="filterStockCatByStatus('Total')"
                    style="cursor: pointer;" title="Afficher tous les articles de cette catégorie">
                    <div class="stat-icon-wrapper"><i class="fas fa-layer-group"></i></div>
                    <div class="stat-info">
                        <div class="stat-value" id="stockCatTotalCount">0</div>
                        <div class="stat-label">Total Articles</div>
                    </div>
                </div>
                <div class="stat-card dist-card-returned" onclick="filterStockCatByStatus('En Stock')"
                    style="cursor: pointer;" title="Filtrer par articles disponibles">
                    <div class="stat-icon-wrapper"><i class="fas fa-check-circle"></i></div>
                    <div class="stat-info">
                        <div class="stat-value" id="stockCatEnStockCount">0</div>
                        <div class="stat-label">Articles Disponibles</div>
                    </div>
                </div>
                <div class="stat-card printer-card-offline" onclick="filterStockCatByStatus('Rupture')"
                    style="cursor: pointer;" title="Filtrer par articles en rupture de stock">
                    <div class="stat-icon-wrapper"><i class="fas fa-times-circle"></i></div>
                    <div class="stat-info">
                        <div class="stat-value" id="stockCatRuptureCount">0</div>
                        <div class="stat-label">Rupture de Stock</div>
                    </div>
                </div>
            </div>

            <div class="data-table-wrapper">
                <div class="table-header"
                    style="display: flex; justify-content: space-between; align-items: center; gap: 1rem; flex-wrap: wrap;">
                    <h3 id="catTableTitle"
                        style="margin: 0; font-size: 1.2rem; font-weight: 600; color: var(--text-primary);">Articles
                        enregistrés</h3>
                    <div class="table-actions">
                        <div class="table-search-field module-search-field">
                            <i class="fas fa-search"></i>
                            <input type="text" placeholder="Recherche rapide..." id="stockSearchInput"
                                oninput="filterStockTable()"
                                onfocus="this.parentElement.style.borderColor='var(--blue-500)'; this.parentElement.style.boxShadow='0 0 0 3px rgba(59,130,246,0.1)';"
                                onblur="this.parentElement.style.borderColor='var(--border-color)'; this.parentElement.style.boxShadow='none';">
                        </div>
                    </div>
                </div>
                <div class="table-responsive">
                    <table class="stock-category-table">
                        <thead>
                            <tr>
                                <th>Désignation (Nom)</th>
                                <th>Référence / S/N</th>
                                <th>Code RF</th>
                                <th style="text-align: center;">Quantité</th>
                                <th>Emplacement</th>
                                <th>Date Réception</th>
                                <th>Observations</th>
                                <th style="width: 120px; text-align: center;">Actions</th>
                            </tr>
                        </thead>
                        <tbody id="stockCategoryTableBody">
                            <!-- Populated dynamically via JavaScript -->
                        </tbody>
                    </table>
                </div>
                <!-- Stock Category pagination switcher -->
                <div id="stockCategoryPagination" class="pagination-container"></div>
            </div>
        </div>

        <!-- Distribution & Prêt View -->
        <div id="distributionView" class="view-container">
            <div class="view-header distribution-toolbar">
                <div class="view-title-box">
                    <div class="view-icon" style="background: var(--gradient-emerald-teal);"><i
                            class="fas fa-hand-holding"></i></div>
                    <div class="view-title-text">
                        <h2>Distribution & Prêt de Matériel</h2>
                        <p>Suivi des distributions et prêts de matériel IT aux employés.</p>
                    </div>
                </div>
                <div class="view-toolbar-actions">
                    <button class="back-btn header-back-btn distribution-back-btn" onclick="showView('dashboardView')" title="Retour au Tableau de Bord" aria-label="Retour au Tableau de Bord">
                        <i class="fas fa-arrow-left"></i>
                    </button>
                    <button class="btn btn-primary" onclick="openDistributionForm()"
                        style="background: var(--gradient-emerald-teal); border: none;">
                        <i class="fas fa-plus"></i> Nouvelle Distribution
                    </button>
                </div>
            </div>

            <!-- Stats Cards -->
            <div class="modules-grid"
                style="grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); margin-bottom: 2rem;">
                <!-- Card 1: Total Distributions -->
                <div class="stat-card dist-card dist-card-total" onclick="filterDistributionByStatus('Total')"
                    style="cursor: pointer;" title="Afficher toutes les distributions">
                    <div class="stat-icon-wrapper"><i class="fas fa-hand-holding"></i></div>
                    <div class="stat-info">
                        <div class="stat-value" id="distTotalCount">0</div>
                        <div class="stat-label">Total Distributions</div>
                    </div>
                </div>
                <!-- Card 2: Prêts en Cours -->
                <div class="stat-card dist-card dist-card-active" onclick="filterDistributionByStatus('Prêt')"
                    style="cursor: pointer;" title="Filtrer par prêts en cours">
                    <div class="stat-icon-wrapper"><i class="fas fa-exchange-alt"></i></div>
                    <div class="stat-info">
                        <div class="stat-value" id="distPretEnCoursCount">0</div>
                        <div class="stat-label">Prêts en Cours</div>
                    </div>
                </div>
                <!-- Card 3: Rendus -->
                <div class="stat-card dist-card dist-card-returned" onclick="filterDistributionByStatus('Rendu')"
                    style="cursor: pointer;" title="Filtrer par matériels rendus">
                    <div class="stat-icon-wrapper"><i class="fas fa-check-circle"></i></div>
                    <div class="stat-info">
                        <div class="stat-value" id="distRenduCount">0</div>
                        <div class="stat-label">Rendus</div>
                    </div>
                </div>
                <!-- Card 4: En Retard -->
                <div class="stat-card dist-card dist-card-late" onclick="filterDistributionByStatus('Retard')"
                    style="cursor: pointer;" title="Filtrer par prêts en retard de restitution">
                    <div class="stat-icon-wrapper"><i class="fas fa-exclamation-circle"></i></div>
                    <div class="stat-info">
                        <div class="stat-value" id="distRetardCount">0</div>
                        <div class="stat-label">En Retard</div>
                    </div>
                </div>
            </div>

            <!-- WiFi Authorization Sub-Module Card -->
            <div class="modules-grid" style="grid-template-columns: 1fr; margin-bottom: 2rem;">
                <div class="module-card" onclick="showWifiAuthView()" style="display: flex; align-items: center; gap: 1.5rem; padding: 1.5rem; background: var(--bg-glass); border: 1px solid var(--border-color); border-radius: 1.2rem; cursor: pointer;">
                    <div class="module-icon" style="font-size: 2.5rem; margin-bottom: 0; color: #10b981; background: rgba(16, 185, 129, 0.1); width: 60px; height: 60px; display: flex; align-items: center; justify-content: center; border-radius: 50%;">
                        <i class="fas fa-wifi"></i>
                    </div>
                    <div style="flex: 1;">
                        <h4 style="margin: 0; font-size: 1.2rem; color: var(--text-primary);">📶 Autorisations Wi-Fi</h4>
                        <p style="margin: 0.25rem 0 0 0; font-size: 0.9rem; color: var(--text-secondary);">Gestion des accès Wi-Fi des téléphones personnels.</p>
                    </div>
                    <button class="btn btn-primary" style="background: var(--gradient-emerald-teal); border: none; padding: 8px 16px; border-radius: 8px; font-weight: 600;">
                        Ouvrir <i class="fas fa-arrow-right" style="margin-left: 5px;"></i>
                    </button>
                </div>
            </div>

            <div class="data-table-wrapper">
                <div class="table-header">
                    <h3>Historique des Distributions</h3>
                    <div class="table-actions">
                        <div class="table-search-field module-search-field">
                            <i class="fas fa-search"></i>
                            <input type="text" placeholder="Rechercher un employé ou un article..." id="distSearchInput"
                                oninput="renderDistributionTable()"
                                onfocus="this.parentElement.style.borderColor='var(--blue-500)'; this.parentElement.style.boxShadow='0 0 0 3px rgba(59,130,246,0.1)';"
                                onblur="this.parentElement.style.borderColor='var(--border-color)'; this.parentElement.style.boxShadow='none';">
                        </div>
                    </div>
                </div>
                <div class="table-responsive">
                    <table class="distribution-table">
                        <thead>
                            <tr>
                                <th>Employé</th>
                                <th>Service</th>
                                <th>Article</th>
                                <th style="text-align: center;">Qté</th>
                                <th style="text-align: center;">Type</th>
                                <th>Date</th>
                                <th style="text-align: center;">Statut</th>
                                <th style="width: 210px; text-align: center;">Actions</th>
                            </tr>
                        </thead>
                        <tbody id="distributionTableBody">
                            <!-- Populated dynamically via JavaScript -->
                        </tbody>
                    </table>
                </div>
                <!-- Distribution pagination switcher -->
                <div id="distributionPagination" class="pagination-container"></div>
            </div>
        </div>

        <!-- Wifi Authorizations View -->
        <div id="wifiAuthView" class="view-container">
            <div class="view-header distribution-toolbar">
                <div class="view-title-box">
                    <div class="view-icon" style="background: var(--gradient-emerald-teal);"><i class="fas fa-wifi"></i></div>
                    <div class="view-title-text">
                        <h2>Registre des Autorisations Wi-Fi</h2>
                        <p>Gestion des accès Wi-Fi des téléphones personnels des employés.</p>
                    </div>
                </div>
                <div class="view-toolbar-actions">
                    <button class="back-btn header-back-btn" onclick="showView('distributionView')" title="Retour aux Distributions" aria-label="Retour aux Distributions">
                        <i class="fas fa-arrow-left"></i>
                    </button>
                    <button class="btn btn-primary" onclick="openWifiForm()"
                        style="background: var(--gradient-emerald-teal); border: none;">
                        <i class="fas fa-plus"></i> Nouvelle Autorisation Wi-Fi
                    </button>
                </div>
            </div>

            <!-- Stats Cards for Wifi -->
            <div class="modules-grid"
                style="grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); margin-bottom: 2rem;">
                <!-- Card 1: Total Wifi -->
                <div class="stat-card dist-card dist-card-total" onclick="filterWifiByStatus('Total')"
                    style="cursor: pointer;" title="Afficher toutes les autorisations">
                    <div class="stat-icon-wrapper"><i class="fas fa-wifi"></i></div>
                    <div class="stat-info">
                        <div class="stat-value" id="wifiTotalCount">0</div>
                        <div class="stat-label">Total Autorisations</div>
                    </div>
                </div>
                <!-- Card 2: Active Wifi -->
                <div class="stat-card dist-card dist-card-active" onclick="filterWifiByStatus('Active')"
                    style="cursor: pointer;" title="Filtrer par autorisations actives">
                    <div class="stat-icon-wrapper" style="color: #10b981;"><i class="fas fa-check-circle"></i></div>
                    <div class="stat-info">
                        <div class="stat-value" id="wifiActiveCount">0</div>
                        <div class="stat-label">Active</div>
                    </div>
                </div>
                <!-- Card 3: Pending Wifi -->
                <div class="stat-card dist-card dist-card-pending" onclick="filterWifiByStatus('En attente')"
                    style="cursor: pointer;" title="Filtrer par autorisations en attente">
                    <div class="stat-icon-wrapper" style="color: #f59e0b;"><i class="fas fa-clock"></i></div>
                    <div class="stat-info">
                        <div class="stat-value" id="wifiPendingCount">0</div>
                        <div class="stat-label">En attente</div>
                    </div>
                </div>
                <!-- Card 4: Revoked/Suspended Wifi -->
                <div class="stat-card dist-card dist-card-revoked" onclick="filterWifiByStatus('Suspendue/Révoquée')"
                    style="cursor: pointer;" title="Filtrer par suspendues ou révoquées">
                    <div class="stat-icon-wrapper" style="color: #ef4444;"><i class="fas fa-ban"></i></div>
                    <div class="stat-info">
                        <div class="stat-value" id="wifiRevokedCount">0</div>
                        <div class="stat-label">Suspendue / Révoquée</div>
                    </div>
                </div>
            </div>

            <!-- Wifi Table Registry -->
            <div class="data-table-wrapper">
                <div class="table-header">
                    <h3>Registre des Autorisations Wi-Fi</h3>
                    <div class="table-actions">
                        <div class="table-search-field module-search-field">
                            <i class="fas fa-search"></i>
                            <input type="text" placeholder="Rechercher un employé, marque..." id="wifiSearchInput"
                                oninput="renderWifiTable()"
                                onfocus="this.parentElement.style.borderColor='var(--blue-500)'; this.parentElement.style.boxShadow='0 0 0 3px rgba(59,130,246,0.1)';"
                                onblur="this.parentElement.style.borderColor='var(--border-color)'; this.parentElement.style.boxShadow='none';">
                        </div>
                    </div>
                </div>
                <div class="table-responsive">
                    <table class="distribution-table">
                        <thead>
                            <tr>
                                <th>N° Autorisation</th>
                                <th>Employé</th>
                                <th>Poste / Département</th>
                                <th>Téléphone</th>
                                <th>Réseau</th>
                                <th>Date d'émission</th>
                                <th style="text-align: center;">Statut</th>
                                <th style="width: 240px; text-align: center;">Actions</th>
                            </tr>
                        </thead>
                        <tbody id="wifiTableBody">
                            <!-- Populated dynamically via JavaScript -->
                        </tbody>
                    </table>
                </div>
                <!-- Wifi pagination switcher -->
                <div id="wifiPagination" class="pagination-container"></div>
            </div>
        </div>

        <!-- Wifi Form View -->
        <div id="wifiFormView" class="view-container">
            <div class="view-header form-toolbar distribution-form-toolbar">
                <div class="view-title-box">
                    <div class="view-icon" style="background: var(--gradient-emerald-teal);">
                        <i class="fas fa-wifi"></i>
                    </div>
                    <div class="view-title-text">
                        <h2 id="wifiFormTitle">Nouvelle Autorisation Wi-Fi</h2>
                        <p id="wifiFormSub">Enregistrer une autorisation d'accès au réseau Wi-Fi de l'entreprise pour un téléphone personnel.</p>
                    </div>
                </div>
                <div class="view-toolbar-actions">
                    <button class="back-btn header-back-btn" onclick="closeWifiForm()" title="Retour aux Autorisations" aria-label="Retour aux Autorisations">
                        <i class="fas fa-arrow-left"></i>
                    </button>
                </div>
            </div>

            <div class="premium-form-container">
                <div class="premium-form-grid">
                    <!-- Section 1: Informations Employé -->
                    <div class="form-section-card">
                        <div class="form-section-title">
                            <i class="fas fa-user-tie"></i> Informations Employé (Bénéficiaire)
                        </div>
                        <div class="premium-input-group">
                            <label>Nom & Prénom</label>
                            <div class="premium-input-wrapper">
                                <input type="text" id="wifiEmployeeName" placeholder="Ex: Mohamed Benali">
                                <i class="fas fa-user"></i>
                            </div>
                        </div>
                        <div class="premium-input-group">
                            <label>Poste Occupé</label>
                            <div class="premium-input-wrapper">
                                <input type="text" id="wifiPoste" placeholder="Ex: Ingénieur Système">
                                <i class="fas fa-briefcase"></i>
                            </div>
                        </div>
                        <div class="premium-input-group" style="margin-bottom: 0;">
                            <label>Service / Département</label>
                            <div class="premium-input-wrapper">
                                <input type="text" id="wifiDept" placeholder="Ex: Informatique, RH, Finance...">
                                <i class="fas fa-building"></i>
                            </div>
                        </div>
                    </div>

                    <!-- Section 2: Informations Téléphone -->
                    <div class="form-section-card">
                        <div class="form-section-title">
                            <i class="fas fa-mobile-alt"></i> Informations Téléphone (Personnel)
                        </div>
                        <div class="premium-input-grid" style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem;">
                            <div class="premium-input-group">
                                <label>Marque</label>
                                <div class="premium-input-wrapper">
                                    <input type="text" id="wifiPhoneBrand" placeholder="Ex: Samsung, Apple, Xiaomi">
                                    <i class="fas fa-tag"></i>
                                </div>
                            </div>
                            <div class="premium-input-group">
                                <label>Modèle</label>
                                <div class="premium-input-wrapper">
                                    <input type="text" id="wifiPhoneModel" placeholder="Ex: Galaxy S24, iPhone 15">
                                    <i class="fas fa-mobile"></i>
                                </div>
                            </div>
                        </div>
                        <div class="premium-input-group">
                            <label>N° Téléphone</label>
                            <div class="premium-input-wrapper">
                                <input type="text" id="wifiPhoneNumber" placeholder="Ex: +213 555 12 34 56">
                                <i class="fas fa-phone"></i>
                            </div>
                        </div>
                        <div class="premium-input-group" style="margin-bottom: 0;">
                            <label>Numéro IMEI</label>
                            <div class="premium-input-wrapper">
                                <input type="text" id="wifiPhoneImei" placeholder="Ex: 358238100765432">
                                <i class="fas fa-barcode"></i>
                            </div>
                        </div>
                    </div>

                    <!-- Section 3: Informations Réseau -->
                    <div class="form-section-card" style="grid-column: span 2;">
                        <div class="form-section-title">
                            <i class="fas fa-network-wired"></i> Informations Réseau & Statut
                        </div>
                        <div class="premium-input-grid" style="display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 1.5rem;">
                            <div class="premium-input-group">
                                <label>SSID Réseau (Nom Wi-Fi)</label>
                                <div class="premium-input-wrapper">
                                    <input type="text" id="wifiSsid" placeholder="Ex: Nedjma-Corporate">
                                    <i class="fas fa-wifi"></i>
                                </div>
                            </div>
                            <div class="premium-input-group">
                                <label>Date d'Attribution</label>
                                <div class="premium-input-wrapper">
                                    <input type="date" id="wifiDate">
                                </div>
                            </div>
                            <div class="premium-input-group">
                                <label>Statut</label>
                                <div class="premium-input-wrapper">
                                    <select id="wifiStatus">
                                        <option value="En attente">En attente</option>
                                        <option value="Active">Active</option>
                                        <option value="Suspendue">Suspendue</option>
                                        <option value="Révoquée">Révoquée</option>
                                        <option value="Expirée">Expirée</option>
                                    </select>
                                    <i class="fas fa-info-circle"></i>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Section 4: Conditions d'Utilisation (Engagement) -->
                    <div class="form-section-card" style="grid-column: span 2; background: rgba(16, 185, 129, 0.02); border: 1px solid rgba(16, 185, 129, 0.15);">
                        <div class="form-section-title" style="color: #10b981;">
                            <i class="fas fa-balance-scale"></i> Conditions d'utilisation du réseau Wi-Fi de l'entreprise (Engagement)
                        </div>
                        
                        <div class="wifi-terms-box" style="background: var(--bg-glass); border: 1px solid var(--border-color); padding: 1.5rem; border-radius: 8px; margin-bottom: 1.5rem; font-size: 0.95rem; line-height: 1.7; max-height: 250px; overflow-y: auto; color: var(--text-primary);">
                            <ol style="margin: 0; padding-left: 1.25rem;">
                                <li>Je m'engage à utiliser le réseau Wi-Fi de l'entreprise uniquement à des fins professionnelles.</li>
                                <li>Je m'engage à ne pas utiliser le réseau pour :
                                    <ul style="margin: 5px 0; padding-left: 1.25rem; list-style-type: circle;">
                                        <li>Visionner des vidéos de divertissement (YouTube, Netflix, TikTok...)</li>
                                        <li>Les jeux en ligne</li>
                                        <li>Les téléchargements personnels</li>
                                        <li>Toute activité non liée au travail</li>
                                    </ul>
                                </li>
                                <li>Je m'engage à ne pas partager le mot de passe du réseau Wi-Fi avec qui que ce soit.</li>
                                <li>Je m'engage à ne pas tenter d'infiltrer, analyser, scanner ou altérer le réseau ou ses systèmes de sécurité.</li>
                                <li>J'accepte que le service informatique surveille et filtre l'activité du réseau à des fins de sécurité et de conformité.</li>
                                <li>J'assume l'entière responsabilité de tout usage non conforme aux règles et chartes informatiques de l'établissement.</li>
                                <li>Le service informatique se réserve le droit de révoquer ou suspendre cette autorisation à tout moment en cas de non-respect de ces clauses.</li>
                            </ol>
                        </div>

                        <div class="premium-input-group" style="margin-bottom: 0;">
                            <label class="checkbox-container" style="display: flex; align-items: flex-start; gap: 0.75rem; cursor: pointer; user-select: none;">
                                <input type="checkbox" id="wifiAgreeCheckbox" style="margin-top: 0.25rem; width: 18px; height: 18px; accent-color: #10b981;">
                                <span style="font-weight: 700; color: var(--text-primary); font-size: 0.95rem; margin-left: 8px;">
                                    Je déclare avoir lu, compris et accepté sans réserve l'intégralité des conditions d'utilisation du réseau Wi-Fi de l'entreprise.
                                </span>
                            </label>
                        </div>
                    </div>
                </div>

                <div class="form-actions" style="margin-top: 2rem; display: flex; justify-content: flex-end; gap: 1rem;">
                    <button class="btn btn-secondary" onclick="closeWifiForm()" style="background: rgba(255, 255, 255, 0.08); color: var(--text-primary); border: 1px solid var(--border-color); padding: 10px 24px; border-radius: 8px; font-weight: 600;">
                        Annuler
                    </button>
                    <button class="btn btn-primary" onclick="saveWifiAuthorization()" style="background: var(--gradient-emerald-teal); border: none; padding: 10px 24px; border-radius: 8px; font-weight: 600; display: flex; align-items: center; gap: 0.5rem;">
                        <i class="fas fa-save"></i> Enregistrer
                    </button>
                </div>
            </div>
        </div>

        <!-- Distribution Form View -->
        <div id="distributionFormView" class="view-container">
            <div class="view-header form-toolbar distribution-form-toolbar">
                <div class="view-title-box">
                    <div class="view-icon" style="background: var(--gradient-emerald-teal);">
                        <i class="fas fa-hand-holding"></i>
                    </div>
                    <div class="view-title-text">
                        <h2 id="distFormTitle">Nouvelle Distribution</h2>
                        <p id="distFormSub">Enregistrer une distribution ou un prêt de matériel à un employé.</p>
                    </div>
                </div>
                <div class="view-toolbar-actions">
                    <button class="back-btn header-back-btn" onclick="closeDistributionForm()" title="Retour aux Distributions" aria-label="Retour aux Distributions">
                        <i class="fas fa-arrow-left"></i>
                    </button>
                </div>
            </div>
            </div>
        </div>

        <!-- Mobile Detail View -->
        <div id="mobileDetailView" class="view-container">
            <div class="view-header mobile-detail-toolbar">
                <div class="view-title-box">
                    <div class="view-icon" style="background: var(--gradient-indigo-sky);">
                        <i class="fas fa-mobile-screen-button"></i>
                    </div>
                    <div class="view-title-text">
                        <h2 id="mobileDetailTitle">Fiche Mobile</h2>
                        <p id="mobileDetailSubtitle">Vue complète du téléphone, tablette ou PDA.</p>
                    </div>
                </div>
                <div class="view-toolbar-actions mobile-detail-actions">
                    <button class="back-btn header-back-btn" onclick="showView('mobilesView')" title="Retour aux Mobiles" aria-label="Retour aux Mobiles">
                        <i class="fas fa-arrow-left"></i>
                    </button>
                    <button class="btn" id="mobileDetailEditBtn" style="background: var(--bg-card); color: var(--text-primary); border: 2px solid var(--border-color);">
                        <i class="fas fa-edit"></i> Modifier
                    </button>
                    <button class="btn btn-primary" id="mobileDetailPrintBtn" style="background: var(--gradient-indigo-sky); border: none;">
                        <i class="fas fa-file-pdf"></i> Décharge PDF
                    </button>
                </div>
            </div>

            <div class="mobile-detail-grid">
                <section class="mobile-detail-hero">
                    <div class="mobile-detail-device-icon">
                        <i id="mobileDetailTypeIcon" class="fas fa-mobile-screen-button"></i>
                    </div>
                    <span class="mobile-detail-type" id="mobileDetailType">Téléphone</span>
                    <h3 id="mobileDetailModel">N/A</h3>
                    <div class="mobile-detail-imei">
                        <i class="fas fa-barcode"></i>
                        <span id="mobileDetailImei">N/A</span>
                    </div>
                    <div class="mobile-detail-status" id="mobileDetailStatus">Affecté</div>

                    <div class="mobile-detail-divider"></div>

                    <div class="mobile-detail-owner">
                        <span>Bénéficiaire</span>
                        <strong id="mobileDetailAssignee">N/A</strong>
                        <small id="mobileDetailService">N/A</small>
                    </div>

                    <button class="btn btn-danger mobile-detail-delete" id="mobileDetailDeleteBtn">
                        <i class="fas fa-trash-alt"></i> Supprimer
                    </button>
                </section>

                <section class="mobile-detail-panel">
                    <div class="mobile-detail-section">
                        <div class="mobile-detail-section-title">
                            <i class="fas fa-user-check"></i>
                            Affectation
                        </div>
                        <div class="mobile-detail-info-grid">
                            <div class="mobile-detail-info-item">
                                <span>Remis par</span>
                                <strong id="mobileDetailRemisPar">N/A</strong>
                            </div>
                            <div class="mobile-detail-info-item">
                                <span>Fonction</span>
                                <strong id="mobileDetailRemisParFonction">N/A</strong>
                            </div>
                            <div class="mobile-detail-info-item">
                                <span>Société</span>
                                <strong id="mobileDetailSociete">N/A</strong>
                            </div>
                            <div class="mobile-detail-info-item">
                                <span>Date de remise</span>
                                <strong id="mobileDetailDate">N/A</strong>
                            </div>
                        </div>
                    </div>

                    <div class="mobile-detail-section">
                        <div class="mobile-detail-section-title">
                            <i class="fas fa-microchip"></i>
                            Équipement
                        </div>
                        <div class="mobile-detail-info-grid">
                            <div class="mobile-detail-info-item">
                                <span>Type</span>
                                <strong id="mobileDetailDeviceType">N/A</strong>
                            </div>
                            <div class="mobile-detail-info-item">
                                <span>Marque</span>
                                <strong id="mobileDetailMarque">N/A</strong>
                            </div>
                            <div class="mobile-detail-info-item">
                                <span>Modèle</span>
                                <strong id="mobileDetailDeviceModel">N/A</strong>
                            </div>
                            <div class="mobile-detail-info-item">
                                <span>Carte SIM / Ligne</span>
                                <strong id="mobileDetailSim">N/A</strong>
                            </div>
                        </div>
                    </div>

                    <div class="mobile-detail-section mobile-detail-notes-section">
                        <div class="mobile-detail-section-title">
                            <i class="fas fa-sticky-note"></i>
                            Observations internes
                        </div>
                        <p id="mobileDetailNotes">Aucune observation particulière.</p>
                    </div>
                </section>
            </div>
        </div>

        <!-- Universal Record Detail View -->
        <div id="recordDetailView" class="view-container">
            <div class="view-header record-detail-toolbar">
                <div class="view-title-box">
                    <div class="view-icon" id="recordDetailIcon" style="background: var(--gradient-blue-cyan);">
                        <i class="fas fa-folder-open"></i>
                    </div>
                    <div class="view-title-text">
                        <h2 id="recordDetailTitle">Détail</h2>
                        <p id="recordDetailSubtitle">Vue complète de l'enregistrement.</p>
                    </div>
                </div>
                <div class="record-detail-actions">
                    <button class="back-btn header-back-btn" id="recordDetailBackBtn" title="Retour" aria-label="Retour">
                        <i class="fas fa-arrow-left"></i>
                    </button>
                    <button class="btn" id="recordDetailEditBtn">
                        <i class="fas fa-edit"></i> Modifier
                    </button>
                    <button class="btn btn-primary" id="recordDetailPrintBtn">
                        <i class="fas fa-file-pdf"></i> PDF
                    </button>
                    <button class="btn btn-danger" id="recordDetailDeleteBtn">
                        <i class="fas fa-trash-alt"></i> Supprimer
                    </button>
                </div>
            </div>

            <div class="record-detail-grid">
                <aside class="record-detail-hero">
                    <div class="record-detail-hero-icon" id="recordDetailHeroIcon">
                        <i class="fas fa-folder-open"></i>
                    </div>
                    <span class="record-detail-type" id="recordDetailType">Module</span>
                    <h3 id="recordDetailMainTitle">Enregistrement</h3>
                    <div class="record-detail-ref" id="recordDetailRef">REF</div>
                    <div class="record-detail-status" id="recordDetailStatus">Statut</div>
                    <div class="record-detail-divider"></div>
                    <div class="record-detail-owner">
                        <span id="recordDetailOwnerLabel">Responsable</span>
                        <strong id="recordDetailOwner">N/A</strong>
                        <small id="recordDetailOwnerSub">N/A</small>
                    </div>
                </aside>

                <section class="record-detail-content">
                    <div class="record-detail-section">
                        <div class="record-detail-section-title">
                            <i class="fas fa-id-card"></i>
                            Informations principales
                        </div>
                        <div class="record-detail-info-grid" id="recordDetailPrimaryGrid"></div>
                    </div>

                    <div class="record-detail-section">
                        <div class="record-detail-section-title">
                            <i class="fas fa-clipboard-list"></i>
                            Détails opérationnels
                        </div>
                        <div class="record-detail-info-grid" id="recordDetailSecondaryGrid"></div>
                    </div>

                    <div class="record-detail-section" id="recordDetailItemsSection">
                        <div class="record-detail-section-title">
                            <i class="fas fa-list-check"></i>
                            Éléments
                        </div>
                        <div class="record-detail-items" id="recordDetailItems"></div>
                    </div>

                    <div class="record-detail-section record-detail-notes-section">
                        <div class="record-detail-section-title">
                            <i class="fas fa-sticky-note"></i>
                            Observations
                        </div>
                        <p id="recordDetailNotes">Aucune observation particulière.</p>
                    </div>
                </section>
            </div>
        </div>

        <!-- Mobile Form View -->
        <div id="mobileFormView" class="view-container">
            <div class="view-header form-toolbar mobile-form-toolbar">
                <div class="view-title-box">
                    <div class="view-icon" style="background: var(--gradient-indigo-sky);">
                        <i class="fas fa-mobile-screen-button"></i>
                    </div>
                    <div class="view-title-text">
                        <h2 id="mobileFormTitle">Nouveau Mobile</h2>
                        <p id="mobileFormSub">Enregistrer un telephone, une tablette ou un PDA.</p>
                    </div>
                </div>
                <div class="view-toolbar-actions">
                    <button class="back-btn header-back-btn" onclick="closeMobileForm()" title="Retour aux Mobiles" aria-label="Retour aux Mobiles">
                        <i class="fas fa-arrow-left"></i>
                    </button>
                </div>
            </div>

            <div class="premium-form-container">
                <div class="premium-form-grid">
                    <div class="form-section-card">
                        <div class="form-section-title">
                            <i class="fas fa-mobile-screen-button"></i> Equipement mobile
                        </div>
                        <div class="premium-input-group">
                            <label>Type d'equipement</label>
                            <div class="premium-input-wrapper">
                                <select id="mobileType">
                                    <option value="Telephone">Téléphone</option>
                                    <option value="Tablette">Tablette</option>
                                    <option value="PDA">PDA</option>
                                </select>
                                <i class="fas fa-layer-group"></i>
                            </div>
                        </div>
                        <div class="premium-input-group">
                            <label>Marque</label>
                            <div class="premium-input-wrapper">
                                <input type="text" id="mobileMarque" placeholder="Ex: Samsung, Zebra, Apple">
                                <i class="fas fa-tag"></i>
                            </div>
                        </div>
                        <div class="premium-input-group">
                            <label>Modèle / Nom du téléphone *</label>
                            <div class="premium-input-wrapper">
                                <input type="text" id="mobileModel" placeholder="Ex: Samsung Galaxy A06">
                                <i class="fas fa-mobile-alt"></i>
                            </div>
                        </div>
                        <div class="premium-input-group" style="margin-bottom: 0;">
                            <label>Numero IMEI *</label>
                            <div class="premium-input-wrapper">
                                <input type="text" id="mobileImei" placeholder="Ex: 351233875811798">
                                <i class="fas fa-barcode"></i>
                            </div>
                        </div>
                    </div>

                    <div class="form-section-card">
                        <div class="form-section-title">
                            <i class="fas fa-user-check"></i> Affectation
                        </div>
                        <div class="premium-input-group">
                            <label>Remis par</label>
                            <div class="premium-input-wrapper">
                                <input type="text" id="mobileRemisPar" placeholder="Ex: BILLEL BOURABA">
                                <i class="fas fa-user-shield"></i>
                            </div>
                        </div>
                        <div class="premium-input-group">
                            <label>Fonction / Poste du remettant</label>
                            <div class="premium-input-wrapper">
                                <input type="text" id="mobileRemisParFonction" placeholder="Ex: IT SUPPORT">
                                <i class="fas fa-briefcase"></i>
                            </div>
                        </div>
                        <div class="premium-input-group">
                            <label>Remis à *</label>
                            <div class="premium-input-wrapper">
                                <input type="text" id="mobileAssignee" placeholder="Nom complet du beneficiaire">
                                <i class="fas fa-user"></i>
                            </div>
                        </div>
                        <div class="premium-input-group">
                            <label>Service / Departement</label>
                            <div class="premium-input-wrapper">
                                <input type="text" id="mobileService" placeholder="Ex: Ordonnanceur">
                                <i class="fas fa-building"></i>
                            </div>
                        </div>
                        <div class="premium-input-group">
                            <label>Société</label>
                            <div class="premium-input-wrapper">
                                <input type="text" id="mobileSociete" placeholder="Ex: LABO NEDJMA">
                                <i class="fas fa-industry"></i>
                            </div>
                        </div>
                        <div class="premium-input-group" style="margin-bottom: 0;">
                            <label>Carte SIM / Ligne</label>
                            <div class="premium-input-wrapper">
                                <input type="text" id="mobileSimNumber" placeholder="Ex: 0770338763">
                                <i class="fas fa-sim-card"></i>
                            </div>
                        </div>
                    </div>

                    <div class="form-section-card">
                        <div class="form-section-title">
                            <i class="fas fa-clipboard-check"></i> Suivi & Decharge
                        </div>
                        <div class="premium-input-group">
                            <label>Date de remise</label>
                            <div class="premium-input-wrapper">
                                <input type="date" id="mobileDate">
                                <i class="fas fa-calendar-alt"></i>
                            </div>
                        </div>
                        <div class="premium-input-group">
                            <label>Statut</label>
                            <div class="premium-input-wrapper">
                                <select id="mobileStatus">
                                    <option value="Affecte">Affecte</option>
                                    <option value="Maintenance">Maintenance</option>
                                </select>
                                <i class="fas fa-info-circle"></i>
                            </div>
                        </div>
                        <div class="premium-input-group" style="margin-bottom: 0;">
                            <label>Observations</label>
                            <div class="premium-input-wrapper">
                                <textarea id="mobileNotes" placeholder="Etat, accessoires, remarque SIM..." style="min-height: 92px;"></textarea>
                            </div>
                        </div>
                    </div>
                </div>

                <div style="display:flex; justify-content: flex-end; gap: 1.5rem; margin-top: 3rem; padding-top: 2rem; border-top: 2px dashed var(--border-color);">
                    <button class="btn" style="padding:1.2rem 3rem; font-size:1.1rem; border-radius:1rem; font-weight:600; background:var(--bg-secondary); color:var(--text-primary); border:2px solid var(--border-color);" onclick="closeMobileForm()">
                        <i class="fas fa-times"></i> Annuler
                    </button>
                    <button class="btn btn-primary" id="saveMobileBtn" style="padding:1.2rem 3rem; font-size:1.1rem; border-radius:1rem; font-weight:600; background: var(--gradient-indigo-sky); border: none;" onclick="saveMobileItem()">
                        <i class="fas fa-save"></i> Enregistrer
                    </button>
                </div>
            </div>
        </div>

        <div id="deviceFormView" class="view-container">
            <div class="view-header form-toolbar device-form-toolbar">
                <div class="view-title-box">
                    <div class="view-icon" style="background: var(--gradient-blue-purple);">
                        <i class="fas fa-laptop-medical"></i>
                    </div>
                    <div class="view-title-text">
                        <h2 id="modalTitle">Nouveau Appareil</h2>
                        <p>Remplissez les informations ci-dessous.</p>
                    </div>
                </div>
                <div class="view-toolbar-actions">
                    <button class="back-btn header-back-btn" onclick="closeAddModal()" title="Retour à l'Inventaire" aria-label="Retour à l'Inventaire">
                        <i class="fas fa-arrow-left"></i>
                    </button>
                </div>
            </div>

            <div class="premium-form-container">

                <div class="form-section-card" style="margin-bottom: 2rem;">
                    <div class="form-section-title">
                        <i class="fas fa-layer-group"></i> Type d'Appareil
                    </div>
                    <!-- Èع اجاز -->
                    <div class="device-type-selector">
                        <label class="type-option">
                            <input type="radio" name="deviceType" value="Laptop" id="typeLaptop" checked>
                            <div class="type-card">
                                <i class="fas fa-laptop"></i>
                                <span>Laptop</span>
                            </div>
                        </label>
                        <label class="type-option">
                            <input type="radio" name="deviceType" value="Desktop" id="typeDesktop">
                            <div class="type-card">
                                <i class="fas fa-computer"></i>
                                <span>PC Bureau</span>
                            </div>
                        </label>
                    </div>
                </div>

                <div class="premium-form-grid">
                    <!-- Section 1 -->
                    <div class="form-section-card">
                        <div class="form-section-title">
                            <i class="fas fa-id-card"></i> Identifiants & Spécs
                        </div>
                        <div class="premium-input-group">
                            <label
                                style="font-size: 0.8rem; opacity: 0.85; color: var(--indigo-500); font-weight: bold; margin-bottom: 0.25rem; display: block;">
                                <i class="fas fa-barcode" style="margin-right: 0.25rem;"></i> Numéro de Série (S/N)
                            </label>
                            <div class="premium-input-wrapper">
                                <input type="text" id="addSN" placeholder="Ex: SN-2024-XXXX">
                            </div>
                        </div>
                        <div class="premium-input-group">
                            <label
                                style="font-size: 0.8rem; opacity: 0.85; color: var(--purple-500); font-weight: bold; margin-bottom: 0.25rem; display: block;">
                                <i class="fas fa-laptop-code" style="margin-right: 0.25rem;"></i> Modèle
                            </label>
                            <div class="premium-input-wrapper">
                                <input type="text" id="addModel" placeholder="Ex: HP ProBook 450 G8">
                            </div>
                        </div>
                        <!-- Hidden main specs field for full compatibility -->
                        <input type="hidden" id="addSpecs">

                        <div class="premium-input-group">
                            <label
                                style="font-size: 0.8rem; opacity: 0.85; color: var(--blue-500); font-weight: bold; margin-bottom: 0.25rem; display: block;">
                                <i class="fas fa-microchip" style="margin-right: 0.25rem;"></i> Processeur (CPU)
                            </label>
                            <div class="premium-input-wrapper">
                                <input type="text" id="addCPU" placeholder="Ex: Intel Core i5"
                                    oninput="assembleSpecs()">
                            </div>
                        </div>
                        <div class="premium-input-group">
                            <label
                                style="font-size: 0.8rem; opacity: 0.85; color: var(--pink-500); font-weight: bold; margin-bottom: 0.25rem; display: block;">
                                <i class="fas fa-memory" style="margin-right: 0.25rem;"></i> Mémoire RAM
                            </label>
                            <div class="premium-input-wrapper">
                                <input type="text" id="addRAM" placeholder="Ex: 16GB RAM" oninput="assembleSpecs()">
                            </div>
                        </div>
                        <div class="premium-input-group">
                            <label
                                style="font-size: 0.8rem; opacity: 0.85; color: var(--amber-500); font-weight: bold; margin-bottom: 0.25rem; display: block;">
                                <i class="fas fa-hdd" style="margin-right: 0.25rem;"></i> Stockage (Disque)
                            </label>
                            <div class="premium-input-wrapper">
                                <input type="text" id="addDisk" placeholder="Ex: 256GB SSD" oninput="assembleSpecs()">
                            </div>
                        </div>
                        <div class="premium-input-group" style="margin-bottom: 0;">
                            <label
                                style="font-size: 0.8rem; opacity: 0.85; color: var(--teal-500); font-weight: bold; margin-bottom: 0.25rem; display: block;">
                                <i class="fas fa-headphones" style="margin-right: 0.25rem;"></i> Accessoires Inclus
                            </label>
                            <div class="premium-input-wrapper">
                                <input type="text" id="addAccessories" placeholder="Ex: Clavier, Souris, Sacoche...">
                            </div>
                        </div>
                    </div>

                    <!-- Section 2 -->
                    <div class="form-section-card">
                        <div class="form-section-title">
                            <i class="fas fa-user-tie"></i> Affectation & Emplacement
                        </div>
                        <div class="premium-input-group">
                            <label
                                style="font-size: 0.8rem; opacity: 0.85; color: var(--blue-500); font-weight: bold; margin-bottom: 0.25rem; display: block;">
                                <i class="fas fa-user" style="margin-right: 0.25rem;"></i> Utilisateur (Employé)
                            </label>
                            <div class="premium-input-wrapper">
                                <input type="text" id="addUser" placeholder="Nom Complet de l'employé">
                            </div>
                        </div>
                        <div class="premium-input-group" style="margin-bottom: 0;">
                            <label
                                style="font-size: 0.8rem; opacity: 0.85; color: var(--purple-500); font-weight: bold; margin-bottom: 0.25rem; display: block;">
                                <i class="fas fa-building" style="margin-right: 0.25rem;"></i> Service / Département
                            </label>
                            <div class="premium-input-wrapper">
                                <input type="text" id="addService" placeholder="Ex: Finance, RH, IT...">
                            </div>
                        </div>
                    </div>

                    <!-- Section 3 -->
                    <div class="form-section-card">
                        <div class="form-section-title">
                            <i class="fas fa-clipboard-check"></i> État & Suivi
                        </div>
                        <div class="premium-input-group">
                            <label
                                style="font-size: 0.8rem; opacity: 0.85; color: var(--emerald-500); font-weight: bold; margin-bottom: 0.25rem; display: block;">
                                <i class="fas fa-info-circle" style="margin-right: 0.25rem;"></i> Statut Actuel
                            </label>
                            <div class="premium-input-wrapper">
                                <select id="addStatus">
                                    <option value="Actif">En Service (Actif)</option>
                                    <option value="Maintenance">En Maintenance</option>
                                </select>
                            </div>
                        </div>
                        <div class="premium-input-group">
                            <label
                                style="font-size: 0.8rem; opacity: 0.85; color: var(--pink-500); font-weight: bold; margin-bottom: 0.25rem; display: block;">
                                <i class="fas fa-calendar-alt" style="margin-right: 0.25rem;"></i> Date d'Affectation
                            </label>
                            <div class="premium-input-wrapper">
                                <input type="date" id="addDate">
                            </div>
                        </div>
                        <div class="premium-input-group" style="margin-bottom: 0;">
                            <label
                                style="font-size: 0.8rem; opacity: 0.85; color: var(--amber-500); font-weight: bold; margin-bottom: 0.25rem; display: block;">
                                <i class="fas fa-sticky-note" style="margin-right: 0.25rem;"></i> Notes / Observations
                            </label>
                            <div class="premium-input-wrapper">
                                <textarea id="addNotes"
                                    placeholder="Remarques particulières, État physique..."></textarea>
                            </div>
                        </div>
                    </div>
                </div>

                <div
                    style="display:flex; justify-content: flex-end; gap: 1.5rem; margin-top: 3rem; padding-top: 2rem; border-top: 2px dashed var(--border-color);">
                    <button class="btn"
                        style="padding:1.2rem 3rem; font-size:1.1rem; border-radius:1rem; font-weight:600; background:var(--bg-secondary); color:var(--text-primary); border:2px solid var(--border-color);"
                        onclick="closeAddModal()">
                        <i class="fas fa-times"></i> Annuler
                    </button>
                    <button class="btn btn-primary" id="saveBtn"
                        style="padding:1.2rem 3rem; font-size:1.1rem; border-radius:1rem; font-weight:600; box-shadow: var(--shadow-glow-blue);">
                        <i class="fas fa-save"></i> Enregistrer l'Appareil
                    </button>
                </div>
            </div>
        </div>

        <!-- Printer Form View (SPA) -->
        <div id="printerFormView" class="view-container">
            <div class="view-header form-toolbar printer-form-toolbar">
                <div class="view-title-box">
                    <div class="view-icon" style="background: var(--gradient-pink-orange);">
                        <i class="fas fa-print"></i>
                    </div>
                    <div class="view-title-text">
                        <h2 id="prnFormTitle">Nouvelle Imprimante</h2>
                        <p id="prnFormDesc">Ajouter une imprimante au parc d'impression.</p>
                    </div>
                </div>
                <div class="view-toolbar-actions">
                    <button class="back-btn header-back-btn" onclick="closePrinterForm()" title="Retour aux Imprimantes" aria-label="Retour aux Imprimantes">
                        <i class="fas fa-arrow-left"></i>
                    </button>
                </div>
            </div>

            <div class="premium-form-container">
                <div class="premium-form-grid">
                    <!-- Section 1 -->
                    <div class="form-section-card">
                        <div class="form-section-title">
                            <i class="fas fa-info-circle"></i> Informations Générales
                        </div>
                        <div class="premium-input-group">
                            <label
                                style="font-size: 0.8rem; opacity: 0.85; color: var(--purple-500); font-weight: bold; margin-bottom: 0.25rem; display: block;">
                                <i class="fas fa-print" style="margin-right: 0.25rem;"></i> Modèle Imprimante
                            </label>
                            <div class="premium-input-wrapper">
                                <input type="text" id="addPrnModel" placeholder="Ex: HP LaserJet Pro M404">
                            </div>
                        </div>
                        <div class="premium-input-group">
                            <label
                                style="font-size: 0.8rem; opacity: 0.85; color: var(--indigo-500); font-weight: bold; margin-bottom: 0.25rem; display: block;">
                                <i class="fas fa-barcode" style="margin-right: 0.25rem;"></i> Numéro de Série (S/N)
                            </label>
                            <div class="premium-input-wrapper">
                                <input type="text" id="addPrnSN" placeholder="Ex: VNB45... ">
                            </div>
                        </div>
                        <div class="premium-input-group" style="margin-bottom: 0;">
                            <label
                                style="font-size: 0.8rem; opacity: 0.85; color: var(--amber-500); font-weight: bold; margin-bottom: 0.25rem; display: block;">
                                <i class="fas fa-cogs" style="margin-right: 0.25rem;"></i> Type d'Imprimante
                            </label>
                            <div class="premium-input-wrapper">
                                <select id="addPrnType">
                                    <option>Laser (Monochrome)</option>
                                    <option>Laser (Couleur)</option>
                                    <option>Jet d'encre</option>
                                    <option>Multifonction (MFP)</option>
                                </select>
                            </div>
                        </div>
                    </div>

                    <!-- Section 2 -->
                    <div class="form-section-card">
                        <div class="form-section-title">
                            <i class="fas fa-map-marker-alt"></i> Emplacement & Réseau
                        </div>
                        <div class="premium-input-group">
                            <label
                                style="font-size: 0.8rem; opacity: 0.85; color: var(--purple-500); font-weight: bold; margin-bottom: 0.25rem; display: block;">
                                <i class="fas fa-building" style="margin-right: 0.25rem;"></i> Service / Emplacement
                            </label>
                            <div class="premium-input-wrapper">
                                <input type="text" id="addPrnLocation" placeholder="Ex: Secrétariat, Bureau RH...">
                            </div>
                        </div>
                        <div class="premium-input-group">
                            <label
                                style="font-size: 0.8rem; opacity: 0.85; color: var(--indigo-500); font-weight: bold; margin-bottom: 0.25rem; display: block;">
                                <i class="fas fa-network-wired" style="margin-right: 0.25rem;"></i> Adresse IP (Réseau)
                            </label>
                            <div class="premium-input-wrapper">
                                <input type="text" id="addPrnIP" placeholder="Ex: 192.168.1.50">
                            </div>
                        </div>
                        <div class="premium-input-group" style="margin-bottom: 0;">
                            <label
                                style="font-size: 0.8rem; opacity: 0.85; color: var(--teal-500); font-weight: bold; margin-bottom: 0.25rem; display: block;">
                                <i class="fas fa-plug" style="margin-right: 0.25rem;"></i> Connexion
                            </label>
                            <div class="premium-input-wrapper">
                                <select id="addPrnConnexion">
                                    <option>Réseau (Ethernet/WiFi)</option>
                                    <option>USB (Locale)</option>
                                </select>
                            </div>
                        </div>
                    </div>

                    <!-- Section 3 -->
                    <div class="form-section-card">
